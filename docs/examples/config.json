                "api_key_env": "COINBASE_API_KEY",
                "secret_env": "COINBASE_SECRET"
            },
            "ccxt:kraken": {
                "enabled": false,
                "exchange_id": "kraken",
                "api_key_env": "KRAKEN_API_KEY",
                "secret_env": "KRAKEN_SECRET"
            },
            "freqtrade": {
                "enabled": false,
                "api_url": "http://localhost:8080",
                "api_key_env": "FREQTRADE_API_KEY"
            }
        },
        "signal_fusion": {
            "default_method": "bayesian",
            "min_confidence": 0.6,
            "signal_sources": [
                "momentum",
                "mean_reversion",
                "volatility",
                "ml_prediction"
