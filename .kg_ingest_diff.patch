+    rdfs:domain bfo:0000001 ; rdfs:range :SpectralCluster ;
+    rdfs:label "member of cluster" ;
+    rdfs:comment "Links an entity to its containing spectral cluster." .
+
+:clusterParent a owl:ObjectProperty, owl:TransitiveProperty ;
+    rdfs:domain :SpectralCluster ; rdfs:range :SpectralCluster ;
+    rdfs:label "cluster parent" ;
+    rdfs:comment """Transitive hierarchical relationship between spectral clusters.
+    Enables multi-level cluster taxonomies.""" .
+
+# ── CONCEPT:KG-2.5 Datatype Properties ──
+
+:eigengapValue a owl:DatatypeProperty ;
+    rdfs:domain :SpectralCluster ; rdfs:range xsd:float ;
+    rdfs:label "eigengap value" ;
+    rdfs:comment "The eigengap that determined this cluster count." .
+
+:clusterCoherence a owl:DatatypeProperty ;
+    rdfs:domain :SpectralCluster ; rdfs:range xsd:float ;
+    rdfs:label "cluster coherence" ;
+    rdfs:comment "Intra-cluster cosine similarity average." .
