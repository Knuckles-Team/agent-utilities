+    rdfs:seeAlso fibo-fi:FinancialInstrument .
+
+:FinancialTransaction a owl:Class ;
+    rdfs:subClassOf bfo:0000015 ;
+    rdfs:label "Financial Transaction" ;
+    rdfs:comment "A financial transaction event. BFO:Process. Aligned to FIBO." .
+
+:Account       a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "Account" ;
+    rdfs:comment "A financial account. BFO:GenericallyDependentContinuant." .
+
+:TradingStrategy a owl:Class ;
+    rdfs:subClassOf :Procedure ;
+    rdfs:label "Trading Strategy" ;
+    rdfs:comment "An algorithmic trading procedure." .
+
+:StationaryFeature a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "Stationary Feature" ;
+    rdfs:comment "A mathematically stationary market feature." .
+
+:MarketRegime a owl:Class ;
+    rdfs:subClassOf :Phase ;
+    rdfs:label "Market Regime" ;
+    rdfs:comment "A specific topological state of the market." .
+
+:NeuralNetworkModel a owl:Class ;
+    rdfs:subClassOf :Tool ;
+    rdfs:label "Neural Network Model" ;
+    rdfs:comment "A trained neural network model." .
+
+:LSTMNetwork a owl:Class ;
+    rdfs:subClassOf :NeuralNetworkModel ;
+    rdfs:label "LSTM Network" ;
+    rdfs:comment "A Long Short-Term Memory neural network." .
+
+:ExecutionSignal a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "Execution Signal" ;
+    rdfs:comment "A directional market signal generated by a model." .
+
+:KellySizing a owl:Class ;
+    rdfs:subClassOf :Procedure ;
+    rdfs:label "Kelly Sizing" ;
+    rdfs:comment "A position sizing procedure using the Kelly Criterion." .
+
+# ── Finance Domain Extension (KG-2.60 through KG-2.67) ──
+
+:AlphaFactor a owl:Class ;
+    rdfs:subClassOf :StationaryFeature ;
+    rdfs:label "Alpha Factor" ;
+    rdfs:comment "A predictive alpha factor with IC/IR statistics. Subclass of StationaryFeature. CONCEPT:KG-2.6" .
+
+:RiskLimit a owl:Class ;
+    rdfs:subClassOf :Policy ;
+    rdfs:label "Risk Limit" ;
+    rdfs:comment "A risk management policy (max position, VaR limit, drawdown limit). CONCEPT:KG-2.6" .
+
+:VaREstimate a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "VaR Estimate" ;
+    rdfs:comment "A Value at Risk estimate (historical, parametric, or Monte Carlo). CONCEPT:KG-2.6" .
+
+:PortfolioAllocation a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "Portfolio Allocation" ;
+    rdfs:comment "An optimized weight assignment (MVO, Risk Parity, Black-Litterman). CONCEPT:KG-2.6" .
+
+:OrderVersion a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "Order Version" ;
+    rdfs:comment "An immutable versioned snapshot of a trading order. CONCEPT:KG-2.6" .
+
+:OrderCommitRecord a owl:Class ;
+    rdfs:subClassOf bfo:0000015 ;
+    rdfs:label "Order Commit" ;
+    rdfs:comment "An atomic commit of a staged order to execution. BFO:Process. CONCEPT:KG-2.6" .
+
+:MarketDataSource a owl:Class ;
+    rdfs:subClassOf :Tool ;
+    rdfs:label "Market Data Source" ;
+    rdfs:comment "A market data provider (yfinance, CCXT, synthetic). CONCEPT:KG-2.6" .
+
+:PaymentProofEntity a owl:Class ;
+    rdfs:subClassOf :FinancialTransaction ;
+    rdfs:label "Payment Proof" ;
+    rdfs:comment "An x402 payment proof attesting a completed autonomous payment. CONCEPT:KG-2.6" .
+
+:PaymentBudget a owl:Class ;
+    rdfs:subClassOf :Policy ;
+    rdfs:label "Payment Budget" ;
+    rdfs:comment "Budget limits governing autonomous AI agent spending. CONCEPT:KG-2.6" .
+
+:ProfitAttribution a owl:Class ;
+    rdfs:subClassOf :OutcomeEvaluation ;
+    rdfs:label "Profit Attribution" ;
+    rdfs:comment "Alpha/beta/residual P&L decomposition. CONCEPT:KG-2.6" .
+
+:StreamChannel a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "Stream Channel" ;
+    rdfs:comment "A real-time pub/sub streaming topic. CONCEPT:KG-2.6" .
+
+# ── Finance Domain Extension: Phase 2+3 (KG-2.70 through KG-2.76) ──
+
+:KronosModel a owl:Class ;
+    rdfs:subClassOf :NeuralNetworkModel ;
+    rdfs:label "Kronos Foundation Model" ;
+    rdfs:comment "A K-line tokenizer and autoregressive transformer for candlestick forecasting. CONCEPT:KG-2.6" .
+
+:TradingSwarmEntity a owl:Class ;
+    rdfs:subClassOf bfo:0000027 ;
+    rdfs:label "Trading Swarm" ;
+    rdfs:comment "A multi-agent swarm with specialized roles for collaborative trading. CONCEPT:KG-2.6" .
+
+:ChartPattern a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "Chart Pattern" ;
+    rdfs:comment "A detected visual chart pattern (double top, breakout, etc.). CONCEPT:KG-2.6" .
+
+:MarketFeed a owl:Class ;
+    rdfs:subClassOf :StreamChannel ;
+    rdfs:label "Market Feed" ;
+    rdfs:comment "A live market data feed with tick aggregation. CONCEPT:KG-2.6" .
+
+:StrategyExport a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "Strategy Export" ;
+    rdfs:comment "A platform-specific strategy code export (Pine Script, MQL5, TDX). CONCEPT:KG-2.6" .
+
+:ResearchHypothesis a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "Research Hypothesis" ;
+    rdfs:comment "A testable trading hypothesis in the research autopilot. CONCEPT:KG-2.6" .
+
+:StrategyCardEntity a owl:Class ;
+    rdfs:subClassOf bfo:0000031 ;
+    rdfs:label "Strategy Card" ;
+    rdfs:comment "A shareable strategy card with configuration and performance data. CONCEPT:KG-2.6" .
+
+# ── Phase 2+3 Properties ──
+:forecasts a owl:ObjectProperty ;
+    rdfs:domain :KronosModel ; rdfs:range :ExecutionSignal ;
