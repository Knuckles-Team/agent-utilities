+# =====================================================================
+# Knowledge Distillation Classes (CONCEPT:KG-2.2)
+# =====================================================================
+
+:IdeaBlock     a owl:Class ;
+    rdfs:subClassOf :Concept, bfo:0000031 ;
+    rdfs:label "IdeaBlock" ;
+    rdfs:comment """An atomic, structured knowledge unit containing a critical
+    question, trusted answer, governance tags, and entity references.
+    BFO:GenericallyDependentContinuant. Aligned to skos:Concept.
+    Derived from Blockify's IdeaBlock specification (CONCEPT:KG-2.2).""" .
+
+:DistillationRound a owl:Class ;
+    rdfs:subClassOf bfo:0000015 ;
+    rdfs:label "Distillation Round" ;
+    rdfs:comment """A single iteration of the knowledge deduplication process.
+    BFO:Process. Tracks blocks_before, blocks_after, and similarity_threshold
+    for reproducible distillation lineage (CONCEPT:KG-2.2).""" .
+
+# ── CONCEPT:KG-2.2 Object Properties ──
+
+:distilledFrom a owl:ObjectProperty, owl:TransitiveProperty ;
+    rdfs:domain :IdeaBlock ; rdfs:range :IdeaBlock ;
+    rdfs:label "distilled from" ;
+    rdfs:comment """Transitive merge lineage: traces the full derivation chain
+    of an IdeaBlock through iterative deduplication rounds.""" .
+
+:producedInRound a owl:ObjectProperty ;
+    rdfs:domain :IdeaBlock ; rdfs:range :DistillationRound ;
+    rdfs:label "produced in round" ;
+    rdfs:comment "Links an IdeaBlock to the distillation round that produced it." .
+
+# ── CONCEPT:KG-2.2 Datatype Properties ──
+
+:answersQuestion a owl:DatatypeProperty ;
+    rdfs:domain :IdeaBlock ; rdfs:range xsd:string ;
+    rdfs:label "answers question" ;
+    rdfs:comment "The critical question this IdeaBlock answers." .
+
+:trustedAnswer a owl:DatatypeProperty ;
+    rdfs:domain :IdeaBlock ; rdfs:range xsd:string ;
+    rdfs:label "trusted answer" ;
+    rdfs:comment "The validated, factual answer for this IdeaBlock." .
+
+:distillationThreshold a owl:DatatypeProperty ;
+    rdfs:domain :DistillationRound ; rdfs:range xsd:float ;
+    rdfs:label "distillation threshold" ;
+    rdfs:comment "Cosine similarity threshold used in this distillation round." .
+
+:blocksBeforeDistillation a owl:DatatypeProperty ;
+    rdfs:domain :DistillationRound ; rdfs:range xsd:integer ;
+    rdfs:label "blocks before distillation" .
+
+:blocksAfterDistillation a owl:DatatypeProperty ;
+    rdfs:domain :DistillationRound ; rdfs:range xsd:integer ;
+    rdfs:label "blocks after distillation" .
