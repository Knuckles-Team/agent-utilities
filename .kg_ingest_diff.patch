+# ── CONCEPT:KG-2.2: Core Classes ──
+:EngineeringRule a owl:Class ;
+    rdfs:subClassOf :Principle ;
+    rdfs:label "Engineering Rule" ;
+    rdfs:comment """A software engineering rule derived from a canonical book.
+Subclass of Principle — inherits strength, scope, and derivation semantics.
+Adds tier (full/mini/nano), rule classification, bias correction tracking,
+and AHE efficacy scoring for evolutionary rule selection.""" .
+
+:RuleBook a owl:Class ;
+    rdfs:subClassOf :CreativeWork ;
+    rdfs:label "Rule Book" ;
+    rdfs:comment """A canonical software engineering book that is the source
+of engineering rules (e.g., 'Clean Architecture', 'Domain-Driven Design').
+Subclass of CreativeWork for Dublin Core / BIBO alignment.""" .
+
+# ── CONCEPT:KG-2.2: Object Properties ──
+:correctsBias  a owl:ObjectProperty ;
+    rdfs:domain :EngineeringRule ;
+    rdfs:label "corrects bias" ;
+    rdfs:comment "Links a rule to the LLM bias pattern it prevents." .
