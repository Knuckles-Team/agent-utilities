+        "CALL QUERY_VECTOR_INDEX('Article', 'idx_article_embedding', $emb, 5) YIELD node, score RETURN node, score",
+        {"emb": q_emb},
+    )
+    print("Vector Search Result count:", len(res))
+    if res:
+        print(res[0])
+except Exception as e:
+    print("Error:", e)
