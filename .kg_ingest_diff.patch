+# ══════════════════════════════════════════════════════════════════════
+# Agentic-iModels (CONCEPT:AHE-3.3, AHE-3.16, KG-2.17)
+# arXiv:2605.03808 — Agent-interpretable ML model evolution
+# ══════════════════════════════════════════════════════════════════════
+
+:IModel a owl:Class ;
+    rdfs:subClassOf :RegistryNode ;
+    rdfs:comment "An evolved agent-interpretable ML model class with dual-axis fitness (accuracy + LLM readability). Based on arXiv:2605.03808." ;
+    rdfs:label "interpretable model" .
+
+:InterpretabilityTest a owl:Class ;
+    rdfs:subClassOf :EvaluationRecord ;
+    rdfs:comment "A quantitative test result measuring whether an LLM can simulate model predictions from __str__() output alone." ;
+    rdfs:label "interpretability test" .
+
+:ModelDisplay a owl:Class ;
+    rdfs:subClassOf :RegistryNode ;
+    rdfs:comment "An optimized display representation of a model's __str__() output, decoupled from predict() logic." ;
+    rdfs:label "model display" .
+
+:ParetoFrontierEntry a owl:Class ;
+    rdfs:subClassOf :RegistryNode ;
+    rdfs:comment "A model on the Pareto frontier of accuracy vs interpretability." ;
+    rdfs:label "pareto frontier entry" .
+
+:evolvedModel a owl:ObjectProperty, owl:TransitiveProperty ;
+    rdfs:domain :IModel ;
+    rdfs:range :IModel ;
+    rdfs:comment "Transitive evolutionary lineage. If model A evolvedModel B and B evolvedModel C, then A evolvedModel C." ;
+    rdfs:label "evolved model" .
+
+:testedInterpretability a owl:ObjectProperty ;
+    rdfs:domain :IModel ;
+    rdfs:range :InterpretabilityTest ;
+    rdfs:label "tested interpretability" .
+
+:displayOf a owl:ObjectProperty ;
+    rdfs:domain :ModelDisplay ;
+    rdfs:range :IModel ;
+    rdfs:label "display of" .
+
+:paretoDominates a owl:ObjectProperty ;
+    rdfs:domain :IModel ;
+    rdfs:range :IModel ;
+    rdfs:comment "Links a dominating model to a dominated model on both accuracy and interpretability axes." ;
+    rdfs:label "pareto dominates" .
+
+:interpretabilityScore a owl:DatatypeProperty ;
+    rdfs:domain :IModel ;
+    rdfs:range xsd:float ;
+    rdfs:comment "Agent interpretability pass rate (0.0-1.0) from LLM-graded tests." ;
+    rdfs:label "interpretability score" .
+
+:predictiveRank a owl:DatatypeProperty ;
+    rdfs:domain :IModel ;
+    rdfs:range xsd:float ;
+    rdfs:comment "Normalized RMSE rank across datasets (0.0=best, 1.0=worst)." ;
+    rdfs:label "predictive rank" .
+
+:displayStrategy a owl:DatatypeProperty ;
+    rdfs:domain :ModelDisplay ;
+    rdfs:range xsd:string ;
+    rdfs:comment "Display optimization strategy: linear_collapse, piecewise_table, symbolic_equation, coefficient_summary, adaptive." ;
+    rdfs:label "display strategy" .
