+                for row in results:
+                    src = row.get("source", "")
+                    tgt = row.get("target", "")
+                    if not any(
+                        e["source"] == src and e["target"] == tgt for e in edges
+                    ):
+                        edges.append(
+                            {
+                                "source": src,
+                                "target": tgt,
+                                "type": "depends_on",
+                                "weight": 1.0,
+                            }
+                        )
+            except Exception:
+                pass  # nosec
+
+        return edges
