# ═══════════════════════════════════════════════════════════════════════════════
# agent-utilities — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set for the agent to start successfully.
# Variables marked [OPTIONAL] have sensible defaults.
#
# See docs/development.md for the full environment variable reference.
# ═══════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────────
#  LLM Provider Configuration                              CONCEPT:AU-002
# ───────────────────────────────────────────────────────────────────────────────
# [REQUIRED] Primary LLM endpoint and credentials
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=your-api-key-here
MODEL_ID=openai:gpt-4o
PROVIDER=openai                                # openai | anthropic | groq | mistral | google

# [OPTIONAL] Router model override (uses MODEL_ID if unset)
# GRAPH_ROUTER_BASE_URL=
# GRAPH_ROUTER_API_KEY=

# [OPTIONAL] Embedding provider
# EMBEDDING_PROVIDER=openai                    # openai | huggingface | local
# HF_HOME=~/.cache/huggingface                # HuggingFace model cache path

# [OPTIONAL] Model tuning parameters
# EXTRA_BODY=                                  # JSON string for extra model body params
# EXTRA_HEADERS=                               # JSON string for extra request headers
# LOGIT_BIAS=                                  # JSON string for logit bias
# STOP_SEQUENCES=                              # Comma-separated stop sequences
# MODELS_CONFIG=                               # Path to models.yaml for multi-model routing


# ───────────────────────────────────────────────────────────────────────────────
#  Agent Identity & Workspace                              CONCEPT:AU-001
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Agent identity defaults
# DEFAULT_AGENT_NAME=Agent                     # Display name for the agent
# AGENT_WORKSPACE=.                            # Root workspace path
# ACP_SESSION_ROOT=~/.agent-utilities/sessions # Session persistence directory

# [OPTIONAL] Agent server host/port
# AGENT_HOST=0.0.0.0
# AGENT_PORT=8000


# ───────────────────────────────────────────────────────────────────────────────
#  Provider API Keys                                       CONCEPT:AU-002
# ───────────────────────────────────────────────────────────────────────────────
# Set the key(s) for the provider(s) you intend to use.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=                             # Custom OpenAI-compatible endpoint
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# GEMINI_API_KEY=
# HUGGING_FACE_API_KEY=


# ───────────────────────────────────────────────────────────────────────────────
#  Security & Authentication                               CONCEPT:AU-011
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] TLS and validation
# SSL_VERIFY=true                              # Set to 'false' for self-signed certs
# VALIDATION_MODE=false                        # Enable strict input validation

# [OPTIONAL] API-level authentication for the agent server
# ENABLE_API_AUTH=false                        # Enable X-API-Key header validation
# AGENT_API_KEY=                               # Static API key (legacy)
# AUTH_JWT_JWKS_URI=                           # JWKS endpoint for JWT validation
# AUTH_JWT_ISSUER=                             # Expected JWT issuer
# AUTH_JWT_AUDIENCE=                           # Expected JWT audience
# ALLOWED_ORIGINS=*                            # Comma-separated CORS origins
# ALLOWED_HOSTS=*                              # Comma-separated trusted hosts

# [OPTIONAL] Secrets management backend
# SECRETS_BACKEND=inmemory                     # inmemory | sqlite | vault
# SECRETS_SQLITE_PATH=~/.agent-utilities/secrets.db
# SECRETS_VAULT_URL=http://127.0.0.1:8200
# SECRETS_VAULT_MOUNT=secret
# VAULT_TOKEN=                                 # Vault authentication token
# AGENT_SECRETS_MASTER_KEY=                    # Base64 Fernet key (auto-generated if omitted)

# [OPTIONAL] User session token (injected by MCP middleware)
# AGENT_USER_TOKEN=


# ───────────────────────────────────────────────────────────────────────────────
#  MCP Server Configuration                                CONCEPT:AU-010
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Transport & config
# TRANSPORT=stdio                              # stdio | streamable-http | sse
# MCP_CONFIG_PATH=mcp_config.json              # Path to MCP server definitions
# MCP_URL=                                     # Direct MCP server URL

# [OPTIONAL] MCP JWT/OIDC authentication
# FASTMCP_SERVER_AUTH_JWT_JWKS_URI=
# FASTMCP_SERVER_AUTH_JWT_ISSUER=
# FASTMCP_SERVER_AUTH_JWT_AUDIENCE=
# FASTMCP_SERVER_AUTH_JWT_ALGORITHM=           # HS256 | RS256 | ES256 etc.
# FASTMCP_SERVER_AUTH_JWT_PUBLIC_KEY=
# FASTMCP_SERVER_AUTH_JWT_REQUIRED_SCOPES=     # Comma-separated scopes

# [OPTIONAL] OIDC delegation
# ENABLE_DELEGATION=false
# AUDIENCE=
# DELEGATED_SCOPES=api
# OIDC_CONFIG_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# [OPTIONAL] OpenAPI import credentials
# OPENAPI_USERNAME=
# OPENAPI_PASSWORD=
# OPENAPI_CLIENT_ID=
# OPENAPI_CLIENT_SECRET=

# [OPTIONAL] Tool category toggles (comma-separated or boolean)
# A2A_TOOLS=true
# BROWSER_TOOLS=true
# DEVELOPER_TOOLS=true
# GIT_TOOLS=true
# SCHEDULER_TOOLS=true
# WORKSPACE_TOOLS=true


# ───────────────────────────────────────────────────────────────────────────────
#  Knowledge Graph                                         CONCEPT:AU-013
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Graph backend selection
# GRAPH_BACKEND=networkx                       # networkx | ladybugdb | neo4j | stardog
# GRAPH_DB_PATH=./agent_data/knowledge.db      # Local DB path (ladybugdb)
# LADYBUG_MAX_DB_SIZE=10737418240              # Max DB size in bytes (10GB default)
# KNOWLEDGE_GRAPH_SYNC_BACKGROUND=false        # Enable async background sync

# [OPTIONAL] Remote graph backends
# GRAPH_DB_HOST=localhost
# GRAPH_DB_PORT=7687
# GRAPH_DB_USER=neo4j
# GRAPH_DB_PASSWORD=
# GRAPH_DB_NAME=agentdb
# GRAPH_DB_URI=                                # Full connection URI (overrides host/port)
# GRAPH_TIMEOUT=30                             # Query timeout in seconds

# [OPTIONAL] OWL/ontology backend
# OWL_BACKEND=owlready2                        # owlready2 | rdflib | stardog
# OWL_DB_PATH=./agent_data/ontology.db

# [OPTIONAL] Stardog-specific
# STARDOG_DATABASE=agentdb
# STARDOG_USER=admin
# STARDOG_PASSWORD=

# [OPTIONAL] PostgreSQL/Redis (for distributed deployments)
# POSTGRES_DSN=
# REDIS_URL=


# ───────────────────────────────────────────────────────────────────────────────
#  Observability                                           CONCEPT:AU-019
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] OpenTelemetry
# ENABLE_OTEL=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_EXPORTER_OTLP_PUBLIC_KEY=               # Logfire public key
# OTEL_EXPORTER_OTLP_SECRET_KEY=               # Logfire secret key
# LOGFIRE_TOKEN=                               # Pydantic Logfire token
# LANGFUSE_SECRET_KEY=                         # Langfuse tracing key


# ───────────────────────────────────────────────────────────────────────────────
#  Resource-Aware Optimization                             CONCEPT:AU-016
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Resource optimization weights (0.0 – 1.0, must sum to 1.0)
# RESOURCE_WEIGHT_COST=0.4
# RESOURCE_WEIGHT_LATENCY=0.3
# RESOURCE_WEIGHT_QUALITY=0.3

# [OPTIONAL] Session budgets
# SESSION_TOKEN_BUDGET=100000                  # Max tokens per session
# SESSION_COST_BUDGET_USD=1.0                  # Max cost per session (USD)
# SESSION_LATENCY_BUDGET_MS=30000              # Max latency per session (ms)


# ───────────────────────────────────────────────────────────────────────────────
#  Feature Flags                                           CONCEPT:AU-007
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Runtime feature toggles
# ENABLE_RLM=false                             # Enable Reasoning Language Model
# RLM_USE_CONTAINER=false                      # Run RLM in container
# ENABLE_WEB_UI=false                          # Enable AG-UI web interface
# ENABLE_COUNCIL=false                         # Enable multi-agent council
# GRAPH_DIRECT_EXECUTION=true                  # Bypass LLM tool-call hop in AG-UI/ACP
# SKILL_TYPES=universal,graphs                 # Comma-separated skill types to load


# ───────────────────────────────────────────────────────────────────────────────
#  Testing & Development
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Test-only flags (do NOT set in production)
# AGENT_UTILITIES_TESTING=false                # Enable test mode (disables real LLM calls)
# OTEL_SDK_DISABLED=true                       # Disable OTel SDK during tests
