# Environment Configuration Template
# Copy this file to .env and fill in your values
# See docs/development.md for full environment variable reference

# --- LLM Provider Configuration ---
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=openai:gpt-4o

# --- Agent Server ---
# AGENT_HOST=0.0.0.0
# AGENT_PORT=8000
# DEFAULT_AGENT_NAME=MyAgent

# --- Security ---
# SSL_VERIFY=true
# VALIDATION_MODE=false
# ENABLE_API_AUTH=false            # Enable X-API-Key header validation
# AGENT_API_KEY=                   # Static API key (legacy)
# AUTH_JWT_JWKS_URI=               # JWKS endpoint for JWT validation (e.g. https://login.microsoftonline.com/.../discovery/v2.0/keys)
# AUTH_JWT_ISSUER=                 # Expected JWT issuer
# AUTH_JWT_AUDIENCE=               # Expected JWT audience
# ALLOWED_ORIGINS=                 # Comma-separated CORS origins (default: *)
# ALLOWED_HOSTS=                   # Comma-separated trusted hosts (default: *)

# --- Observability ---
# ENABLE_OTEL=false
# LOGFIRE_TOKEN=your-logfire-token

# --- MCP Configuration ---
# MCP_CONFIG_PATH=mcp_config.json

# --- Knowledge Graph ---
# KG_BACKEND=ladybugdb
# KG_DB_PATH=./agent_data/knowledge.db

# --- Optional Provider API Keys ---
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key
# GROQ_API_KEY=your-groq-key
# MISTRAL_API_KEY=your-mistral-key

# --- Feature Flags ---
# SKILL_TYPES=universal,graphs
# ENABLE_COUNCIL=false
# GRAPH_DIRECT_EXECUTION=true  # Bypass LLM tool-call hop in AG-UI/ACP (default: true)

# --- Secrets Management ---
# SECRETS_BACKEND=inmemory        # inmemory | sqlite | vault
# SECRETS_SQLITE_PATH=~/.agent-utilities/secrets.db
# SECRETS_VAULT_URL=http://127.0.0.1:8200
# SECRETS_VAULT_MOUNT=secret
# AGENT_SECRETS_MASTER_KEY=       # Base64 Fernet key (auto-generated if omitted)
