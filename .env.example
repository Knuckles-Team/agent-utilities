# ═══════════════════════════════════════════════════════════════════════════════
# agent-utilities — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and configure your values.
#
# IMPORTANT: All LLM model registries (models, specific base URLs, API keys)
# should be managed centrally via the XDG-compliant configuration file at:
#   ~/.config/agent-utilities/config.json
#
# Environment variables defined in this file act as secondary overrides for all
# system settings. List or dictionary variables can be passed as JSON strings.
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
#  ⚠️  DEPRECATED / LEGACY LLM SETTINGS (DO NOT USE)
# ───────────────────────────────────────────────────────────────────────────────
# These legacy variables are deprecated and will be ignored in favor of the XDG
# config.json registries (chat_models / embedding_models):
#
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=your-api-key-here
# MODEL_ID=openai:gpt-4o
# PROVIDER=openai
# GRAPH_ROUTER_BASE_URL=
# GRAPH_ROUTER_API_KEY=
# EMBEDDING_PROVIDER=openai
# AGENT_WORKSPACE=.                            # Replaced by WORKSPACE_PATH
# AGENT_HOST=0.0.0.0                           # Replaced by HOST
# AGENT_PORT=8000                              # Replaced by PORT
# MCP_CONFIG_PATH=mcp_config.json              # Replaced by MCP_CONFIG


# ───────────────────────────────────────────────────────────────────────────────
#  1. Primary Model Registry (JSON Overrides)
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] JSON string array of chat models. Overrides config.json registries.
# CHAT_MODELS='[{"id":"qwen/qwen3.5-9b","provider":"openai","base_url":"http://vllm-embed.arpa/v1","supports_json":false,"vision":true,"reasoning":true,"tools_enabled":true,"parallel_instances":3,"context_window":256000,"intelligence_level":"normal","can_route":true,"can_kg":true}]'

# [OPTIONAL] JSON string array of embedding models. Overrides config.json registries.
# EMBEDDING_MODELS='[{"id":"text-embedding-nomic-embed-text-v2-moe","provider":"openai","base_url":"http://vllm-embed.arpa/v1","parallel_instances":4,"chunk_size":768}]'


# ───────────────────────────────────────────────────────────────────────────────
#  2. Global Provider API Keys (Fallbacks)
# ───────────────────────────────────────────────────────────────────────────────
# Set key/endpoint overrides for providers if they are not defined in config.json:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIzaSy...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# HUGGING_FACE_API_KEY=hf_...
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1


# ───────────────────────────────────────────────────────────────────────────────
#  3. Agent Identity & Workspaces
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Agent display identity
# DEFAULT_AGENT_NAME=Agent
# AGENT_DESCRIPTION="AI Agent"
# AGENT_SYSTEM_PROMPT=

# [OPTIONAL] System workspace path (where filesystem and repository tools execute)
# WORKSPACE_PATH=/home/apps/workspace

# [OPTIONAL] Custom XDG configuration root path
# AGENT_UTILITIES_CONFIG_DIR=~/.config/agent-utilities


# ───────────────────────────────────────────────────────────────────────────────
#  4. Server Network Settings
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Core protocol server network settings
# HOST=0.0.0.0
# PORT=9000
# DEBUG=false

# [OPTIONAL] UI Toggles
# ENABLE_WEB_UI=false
# ENABLE_TERMINAL_UI=false
# ENABLE_WEB_LOGS=true

# [OPTIONAL] Agent Control Protocol (ACP) parameters
# ENABLE_ACP=false
# ACP_PORT=8001
# ACP_SESSION_ROOT=.acp-sessions
# DEFAULT_TERMINAL_AGENT=agent-terminal-ui


# ───────────────────────────────────────────────────────────────────────────────
#  5. Security & Authentication
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] API basic authorization and file transfer controls
# ENABLE_API_AUTH=false
# AGENT_API_KEY=my-secure-api-key
# MAX_UPLOAD_SIZE=10485760                     # Limit upload size in bytes (10MB default)

# [OPTIONAL] OIDC / JWT Token Verification
# AUTH_JWT_JWKS_URI=https://identity.provider/keys
# AUTH_JWT_ISSUER=https://identity.provider
# AUTH_JWT_AUDIENCE=my-agent-client-id

# [OPTIONAL] OIDC Client Delegation (RFC 8693 Token Exchange)
# OIDC_CONFIG_URL=https://identity.provider/.well-known/openid-configuration
# OIDC_CLIENT_ID=client-id
# OIDC_CLIENT_SECRET=client-secret
# ENABLE_DELEGATION=false
# AUDIENCE=https://downstream.api/v1           # Target audience for exchange
# DELEGATED_SCOPES=api                         # Space-separated scopes

# [OPTIONAL] CORS & Host Security
# ALLOWED_ORIGINS=*                            # Comma-separated CORS origins
# ALLOWED_HOSTS=*                              # Comma-separated trusted hosts


# ───────────────────────────────────────────────────────────────────────────────
#  6. Secrets Storage Backend
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Secret backends (inmemory, sqlite, vault)
# SECRETS_BACKEND=inmemory
# SECRETS_SQLITE_PATH=~/.agent-utilities/secrets.db
# SECRETS_VAULT_URL=http://127.0.0.1:8200
# SECRETS_VAULT_MOUNT=secret

# [OPTIONAL] Vault / OpenBao Auth & Settings (used with 'vault' backend)
# VAULT_AUTH_METHOD=auto                       # auto | oidc | approle | token | kubernetes
# VAULT_AUTH_MOUNT=jwt                         # Auth mount path
# VAULT_ROLE=default                           # Login role name
# VAULT_PATH_PREFIX=agents/mcp/                # KV v2 path prefix
# AGENT_SECRETS_FILE=                          # Path to custom JSON secrets file


# ───────────────────────────────────────────────────────────────────────────────
#  7. Graph Orchestration & Persistence
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Knowledge-graph backend selection.
# Out-of-box default (when unset): "tiered" — L1 epistemic_graph + L2 LadybugDB.
# This runs as a single self-contained binary with NO external system
# dependencies (no Postgres/Neo4j server needed).
# GRAPH_BACKEND=tiered                         # tiered | memory | file | epistemic_graph | postgresql | ladybug | falkordb | neo4j
# GRAPH_BACKEND_L1=epistemic_graph             # tiered L1 working store
# GRAPH_BACKEND_L2=ladybug                     # tiered L2 durable store; "postgresql" for prod
# To use PostgreSQL as the durable L2 (production), set a DSN — L2 auto-switches to postgres:
# GRAPH_DB_URI=postgresql://agent:agent@localhost:5432/agent_kg
# GRAPH_DB_PATH=~/.local/share/agent-utilities/kg/knowledge_graph.db   # LadybugDB file path
# [OPTIONAL] Graph Orchestration routing and validations
# ROUTING_STRATEGY=hybrid                      # hybrid | semantic | rule-based
# GRAPH_PERSISTENCE_TYPE=file                  # file | memory
# GRAPH_PERSISTENCE_PATH=~/.local/share/agent-utilities/graph_state
# ENABLE_LLM_VALIDATION=false                  # Validate outputs via additional LLM passes
# GRAPH_ROUTER_TIMEOUT=300.0                   # Router maximum timeout in seconds
# GRAPH_VERIFIER_TIMEOUT=300.0                 # Verifier maximum timeout in seconds
# GRAPH_DIRECT_EXECUTION=true                  # Direct graph dispatch (bypasses LLM tool call hop)
# MIN_CONFIDENCE=0.4                           # Routing decision confidence threshold
# VALIDATION_MODE=false                        # Mock LLM generation for CI/testing
# APPROVAL_TIMEOUT=0.0                         # Seconds to wait for manual human approval (0 = block)


# ───────────────────────────────────────────────────────────────────────────────
#  8. Knowledge Graph Ingestion & Tuning
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Graph timeouts and structural constraints
# GRAPH_TIMEOUT=1200000                        # Global network/query timeout in ms
# MAX_RECURSION_DEPTH=2                        # Maximum graph expansion depth
# ROUTING_PERCENTILE=50.0                      # Semantic routing percentile limit
# KG_EMBEDDING_DIM=768                         # Knowledge Graph embedding dimension size

# [OPTIONAL] Knowledge Graph Sync and Concurrency
# ENABLE_KG_EMBEDDINGS=true
# KG_BACKUPS=3                                 # Keep N timestamped SQLite/DuckDB backups
# KG_INGESTION_WORKERS=                        # Max worker threads for codebase ingestion
# KG_LLM_CONCURRENCY=4                         # Max concurrent LLM calls for KG analysis
# KG_ANALYSIS_MAX_DEPTH=2                      # Ingestion graph analyzer recursion depth
# KNOWLEDGE_GRAPH_SYNC_BACKGROUND=true        # Sync knowledge graph in the background
# MODEL_REGISTRY_PATH=                         # Path to models.yaml registry


# ───────────────────────────────────────────────────────────────────────────────
#  9. Observability & Telemetry
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] OpenTelemetry (OTLP) Exports
# ENABLE_OTEL=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://langfuse.arpa/api/public/otel
# OTEL_EXPORTER_OTLP_HEADERS=
# OTEL_EXPORTER_OTLP_PUBLIC_KEY=lf_pk_...
# OTEL_EXPORTER_OTLP_SECRET_KEY=lf_sk_...
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# [OPTIONAL] Langfuse Observability Integration
# LANGFUSE_PUBLIC_KEY=lf_pk_...
# LANGFUSE_SECRET_KEY=lf_sk_...
# LANGFUSE_BASE_URL=http://langfuse.arpa
# LANGFUSE_DATASET_CAPTURE_THRESHOLD=0.0       # Capture score threshold for dataset creation
# LANGFUSE_LATENCY_BASELINE_SECONDS=60.0       # Alert baseline latency
# LANGFUSE_TOKEN_BASELINE=20000                # Expected token limit warning threshold
# LANGFUSE_VERIFIER_FALLBACK_LIMIT=1           # Retries before verification fallback

# [OPTIONAL] Fleet events webhook ingress (CONCEPT:OS-5.15)
# POST /api/fleet/events accepts Alertmanager v4 / Uptime Kuma / generic JSON
# webhooks, persists them as FleetEvent KG nodes and queues fleet_event_triage
# tasks. Alertmanager/Kuma can't mint JWTs, so an optional shared secret gates
# the endpoint instead. Unset = no token required.
# FLEET_EVENTS_TOKEN=

# [OPTIONAL] Autonomous evolution (docs/guides/autonomous-evolution.md)
# The daemon ticks are registered but OFF by default in code — turning a fleet
# autonomous is a DEPLOYMENT decision, made here, not a code default. The
# safety chain stays propose-only end-to-end unless auto-merge is also enabled:
# propose-only loops → governed validation (AHE-3.20) → regression gate → human merge.
# KG_GOLDEN_LOOP=true                          # Hourly propose-only research/self-evolution cycle
# KG_GOLDEN_LOOP_INTERVAL=3600
# KG_GOLDEN_LOOP_TOPICS=5
# KG_FAILURE_EVOLUTION=true                    # Langfuse failures → failure_gap topics → remediation proposals
# KG_FAILURE_EVOLUTION_INTERVAL=3600
# KG_ANOMALY_CONSUMER=true                     # Consume PerformanceAnomaly nodes → failure_gap topics (cheap, propose-only; default on)
# Governed auto-merge: proposal→active promotion gated by the production
# PromotionGovernanceValidator (SHACL + recorded regression gate + MergePolicy
# + constitution rules). Keep FALSE until you trust the proposal stream.
# KG_GOLDEN_AUTO_MERGE=false
# KG_GOLDEN_MERGE_THRESHOLD=0.85


# ───────────────────────────────────────────────────────────────────────────────
#  10. Agent-to-Agent (A2A) Discovery
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Standardized A2A communication parameters
# A2A_BROKER=in-memory
# A2A_BROKER_URL=
# A2A_STORAGE=in-memory
# A2A_STORAGE_URL=
# A2A_CONFIG=                                  # Path to external a2a_config.json
# A2A_REFRESH_INTERVAL=300                     # Period (sec) for card refresh


# ───────────────────────────────────────────────────────────────────────────────
#  11. Specialist Skills
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Loader paths for agent capabilities
# CUSTOM_SKILLS_DIRECTORY=                     # Custom skill packages folder
# SKILL_TYPES=                                 # Comma-separated list of active skill types


# ───────────────────────────────────────────────────────────────────────────────
#  12. LLM Inference Parameters
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Global inference controls and parameters
# MAX_TOKENS=16384
# TEMPERATURE=0.7
# TOP_P=1.0
# TIMEOUT=32400.0
# TOOL_TIMEOUT=32400.0
# PARALLEL_TOOL_CALLS=true
# SEED=
# PRESENCE_PENALTY=0.0
# FREQUENCY_PENALTY=0.0

# [OPTIONAL] LLM formatting controls (JSON format string parameters)
# LOGIT_BIAS=                                  # e.g., '{"5028": -100}'
# STOP_SEQUENCES=                              # e.g., '["\n", "Human:"]'
# EXTRA_HEADERS=                               # e.g., '{"X-Custom": "Val"}'
# EXTRA_BODY=                                  # e.g., '{"presence_penalty": 0.2}'


# ───────────────────────────────────────────────────────────────────────────────
#  13. Cognitive Scheduler & OS Policies
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Priority scheduling and memory policies
# COGNITIVE_SCHEDULER_ENABLED=true
# MAX_CONCURRENT_AGENTS=5
# AGENT_TOKEN_QUOTA=100000
# PREEMPTION_THRESHOLD_PCT=0.85
# AGENT_POLICIES_PATH=                         # Path to agent_policies.json
# PERMISSIONS_SIGNING_KEY=                     # Signature key for agent tokens
# SPECIALIST_REGISTRY_PATH=                    # Local specialist agents catalog directory


# ───────────────────────────────────────────────────────────────────────────────
#  14. Homeostasis & Guardrails
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Homeostatic models and tool protections
# HOMEOSTATIC_DOWNGRADE_ENABLED=true           # Automatically downgrades to light model under load
# ADVERSARIAL_VERIFICATION=false               # Enable double verification checks
# MAINTENANCE_TOKEN_BUDGET=0                   # Unlimited if 0
# MAINTENANCE_PRIORITY=LOW                     # LOW | MEDIUM | HIGH
# WATCHDOG_PATTERNS='["pyproject.toml","mcp_config.json","requirements*.txt"]'

# [OPTIONAL] System safety tool protections
# TOOL_GUARD_MODE=strict                       # strict | lax | off
# SENSITIVE_TOOL_PATTERNS='[".*delete.*",".*remove.*",".*rm_.*",".*rmdir.*",".*drop.*",".*truncate.*",".*prune.*",".*kill.*",".*terminate.*",".*reboot.*",".*shutdown.*",".*install.*",".*uninstall.*",".*redeploy.*",".*bump.*",".*create.*",".*add.*",".*post.*",".*put.*",".*insert.*",".*upload.*",".*ingest.*",".*write.*",".*update.*",".*patch.*",".*set.*",".*reset.*",".*clear.*",".*revert.*",".*replace.*",".*rename.*",".*move.*",".*rotate.*",".*start.*",".*stop.*",".*restart.*",".*pause.*",".*unpause.*",".*execute.*",".*shell.*",".*run_shell.*",".*run_command.*",".*run_script.*",".*run_code.*",".*git_.*",".*clone.*",".*pull.*",".*maintain.*",".*setup.*",".*build.*",".*validate.*",".*sync.*",".*enable.*",".*disable.*",".*activate.*",".*approve.*",".*graphql.*",".*mutation.*",".*http.*",".*eval.*",".*exec.*",".*compile.*",".*socket.*",".*connect.*",".*os\\..*",".*subprocess\\..*",".*shutil\\..*"]'


# ───────────────────────────────────────────────────────────────────────────────
#  15. MCP Tool Server Connections
# ───────────────────────────────────────────────────────────────────────────────
# [OPTIONAL] Core MCP bindings
# MCP_URL=                                     # Remote MCP SSE connection URL
# MCP_CONFIG=mcp_config.json                   # Local multi-server definitions file

# ───────────────────────────────────────────────────────────────────────────────
#  16. KG Background Daemon (single consolidated daemon — CONCEPT:KG-2.8 / OS-5.9)
# ───────────────────────────────────────────────────────────────────────────────
# The KG runs ONE background daemon (queue drain + graph writer + task workers +
# maintenance scheduler + file-watch). KG_DAEMON_ROLE selects who runs it:
#   host   — run the full daemon (set on the API gateway / agent-webui, or run the
#            standalone `graph-os-daemon` process).
#   client — spawn NOTHING; enqueue work to the durable queue the host drains
#            (set on the graph-os MCP server, CLI, and one-shot scripts).
#   auto   — default: in-process consolidated daemon (standalone / dev).
# KG_DAEMON_ROLE=auto
# KG_FILE_WATCH=1                 # set 0 to disable the SDD/skills/scholarx file-watch job
# KG_FILE_WATCH_INTERVAL=30      # seconds between file-watch scans (host only)
