@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

# ── Standard Namespace Prefixes ──────────────────────────────────────
@prefix bfo:    <http://purl.obolibrary.org/obo/BFO_> .
@prefix schema: <http://schema.org/> .
@prefix dc:     <http://purl.org/dc/terms/> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix time:   <http://www.w3.org/2006/time#> .
@prefix bibo:   <http://purl.org/ontology/bibo/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .

<http://knuckles.team/kg> a owl:Ontology ;
    rdfs:label "Agent Intelligence Graph Ontology" ;
    rdfs:comment """Formal OWL ontology for the Unified Intelligence Graph.
Provides BFO-aligned upper ontology classification, industry-standard vocabulary
mappings (PROV-O, Schema.org, Dublin Core, FOAF, SKOS, OWL-Time, BIBO, FIBO),
transitive/subclass/inverse-property reasoning, and full SKOS taxonomy support
over stable LPG data.""" .

# =====================================================================
# BFO Upper Ontology Stubs (ISO 21838-2)
# We declare minimal BFO classes so the reasoner can classify entities
# without requiring a full BFO import.
# =====================================================================
bfo:0000001 a owl:Class ; rdfs:label "Entity" ;
    rdfs:comment "BFO:Entity — root of all entities." .

bfo:0000002 a owl:Class ; rdfs:subClassOf bfo:0000001 ;
    rdfs:label "Continuant" ;
    rdfs:comment "BFO:Continuant — entities that persist through time." .

bfo:0000003 a owl:Class ; rdfs:subClassOf bfo:0000001 ;
    rdfs:label "Occurrent" ;
    rdfs:comment "BFO:Occurrent — entities that unfold or happen over time." .

bfo:0000004 a owl:Class ; rdfs:subClassOf bfo:0000002 ;
    rdfs:label "Independent Continuant" ;
    rdfs:comment "BFO:IndependentContinuant — can exist autonomously." .

bfo:0000020 a owl:Class ; rdfs:subClassOf bfo:0000002 ;
    rdfs:label "Specifically Dependent Continuant" ;
    rdfs:comment "BFO:SpecificallyDependentContinuant — depends on a specific bearer." .

bfo:0000031 a owl:Class ; rdfs:subClassOf bfo:0000002 ;
    rdfs:label "Generically Dependent Continuant" ;
    rdfs:comment "BFO:GenericallyDependentContinuant — information entities." .

bfo:0000015 a owl:Class ; rdfs:subClassOf bfo:0000003 ;
    rdfs:label "Process" ;
    rdfs:comment "BFO:Process — an occurrent that has temporal parts." .

bfo:0000008 a owl:Class ; rdfs:subClassOf bfo:0000003 ;
    rdfs:label "Temporal Region" ;
    rdfs:comment "BFO:TemporalRegion — a region of time." .

# =====================================================================
# Core Classes (BFO-aligned)
# =====================================================================

# ── Independent Continuants (persist, autonomous) ──
:Agent         a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    owl:equivalentClass prov:SoftwareAgent ;
    rdfs:label "Agent Specialist" ;
    rdfs:comment "An autonomous software agent. BFO:IndependentContinuant, aligned to prov:SoftwareAgent." .

:Tool          a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Tool" ;
    rdfs:comment "A software tool or instrument. BFO:IndependentContinuant, aligned to schema:SoftwareApplication." ;
    rdfs:seeAlso schema:SoftwareApplication .

:Skill         a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Skill" ;
    rdfs:comment "A reusable agent skill or capability." .

:File          a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Source File" ;
    rdfs:comment "A source code file." ;
    rdfs:seeAlso schema:DigitalDocument .

:Symbol        a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Code Symbol" .

:Module        a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Module" .

:Server        a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Server" .

:Code          a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Code" ;
    rdfs:seeAlso schema:SoftwareSourceCode .

# ── Organizational Continuants (independent, social entities) ──
:Organization  a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    owl:equivalentClass foaf:Organization ;
    rdfs:label "Organization" ;
    rdfs:comment "An organizational entity. BFO:IndependentContinuant. Aligned to foaf:Organization, schema:Organization, and fibo-org:Organization." ;
    rdfs:seeAlso schema:Organization , fibo-org:Organization .

:Person        a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    owl:equivalentClass foaf:Person ;
    rdfs:label "Person" ;
    rdfs:comment "A human individual. BFO:IndependentContinuant, aligned to foaf:Person and schema:Person." ;
    rdfs:seeAlso schema:Person .

:Role          a owl:Class ;
    rdfs:subClassOf bfo:0000020 ;
    rdfs:label "Role" ;
    rdfs:comment "A time-bounded role a Person plays. BFO:SpecificallyDependentContinuant (a realizable entity — a disposition of a person)." .

:Place         a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Place" ;
    rdfs:comment "A physical, virtual, or contextual location. BFO:IndependentContinuant." ;
    rdfs:seeAlso schema:Place .

:System        a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "System" ;
    rdfs:comment "A software system or service." .

:Team          a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Team" ;
    rdfs:comment "A team of agents or people. BFO:IndependentContinuant." .

# ── Generically Dependent Continuants (information entities) ──
:Memory        a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Memory" ;
    rdfs:comment "A stored memory or knowledge fragment. BFO:GenericallyDependentContinuant, aligned to prov:Entity." ;
    rdfs:seeAlso prov:Entity .

:Fact          a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Fact" ;
    rdfs:comment "An atomic factual assertion. BFO:GenericallyDependentContinuant." ;
    rdfs:seeAlso skos:Concept .

:Concept       a owl:Class ;
    rdfs:subClassOf bfo:0000031 , skos:Concept ;
    rdfs:label "Concept" ;
    rdfs:comment "An atomic knowledge unit. BFO:GenericallyDependentContinuant, aligned to skos:Concept for full SKOS taxonomy support." .

:Evidence      a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Evidence" ;
    rdfs:comment "A claim or finding grounded in source material." .

:Policy        a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Policy" ;
    rdfs:comment "A governance rule or constraint." .

:Principle     a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Principle" ;
    rdfs:comment "A distilled, reusable operational rule." .

# ── Specifically Dependent Continuants (epistemic states) ──
:Belief        a owl:Class ;
    rdfs:subClassOf bfo:0000020 ;
    rdfs:label "Belief" ;
    rdfs:comment "A claim-with-confidence held by an agent. BFO:SpecificallyDependentContinuant." .

:Hypothesis    a owl:Class ;
    rdfs:subClassOf :Belief ;
    rdfs:label "Hypothesis" ;
    rdfs:comment "A falsifiable predictive belief." .

:Reflection    a owl:Class ;
    rdfs:subClassOf bfo:0000020 ;
    rdfs:label "Reflection" ;
    rdfs:comment "A high-level reflective summary." .

# =====================================================================
# Temporal / Event Classes (Occurrents — BFO:Process)
# =====================================================================
:Event         a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Event" ;
    rdfs:comment "A temporally-bounded happening. BFO:Process, aligned to schema:Event and prov:Activity." ;
    owl:equivalentClass schema:Event ;
    rdfs:seeAlso prov:Activity .

:Episode       a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Episode" ;
    rdfs:comment "A discrete interaction unit. BFO:Process, aligned to prov:Activity." ;
    rdfs:seeAlso prov:Activity .

:Incident      a owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:label "Incident" ;
    rdfs:comment "A production incident. Subtype of Event." .

:Decision      a owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:label "Decision" ;
    rdfs:comment "A decision linking Goal → Action → Outcome. Subtype of Event." .

:Observation   a owl:Class ;
    rdfs:subClassOf :Event ;
    rdfs:label "Observation" ;
    rdfs:comment "Something perceived by the agent. Subtype of Event, aligned to prov:Activity." ;
    rdfs:seeAlso prov:Activity .

:Action        a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Action" ;
    rdfs:comment "An agent action. BFO:Process, aligned to prov:Activity." ;
    rdfs:seeAlso prov:Activity .

:ReasoningTrace a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Reasoning Trace" ;
    rdfs:comment "A chain-of-thought step. BFO:Process, aligned to prov:Activity." ;
    rdfs:seeAlso prov:Activity .

# ── Temporal Region ──
:Phase         a owl:Class ;
    rdfs:subClassOf bfo:0000008 ;
    rdfs:label "Temporal Phase" ;
    rdfs:comment "A named temporal interval. BFO:TemporalRegion, aligned to time:ProperInterval." ;
    rdfs:seeAlso time:ProperInterval .

# =====================================================================
# Self-Improvement Classes (BFO-aligned)
# =====================================================================
:OutcomeEvaluation a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Outcome Evaluation" ;
    rdfs:comment "A reward/evaluation record. BFO:GenericallyDependentContinuant." .

:Critique      a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Critique" ;
    rdfs:comment "A textual gradient / critique. BFO:GenericallyDependentContinuant." .

:Goal          a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Goal" ;
    rdfs:comment "An objective the agent is pursuing. BFO:GenericallyDependentContinuant." .

# =====================================================================
# NEW: Cross-Domain Standard-Aligned Classes
# =====================================================================

# ── Document / Publishing Domain (Dublin Core + BIBO) ──
:Document      a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Document" ;
    rdfs:comment "A digital or physical document. BFO:GenericallyDependentContinuant. Aligned to schema:DigitalDocument and bibo:Document." ;
    rdfs:seeAlso schema:DigitalDocument , bibo:Document .

:CreativeWork  a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Creative Work" ;
    rdfs:comment "A book, manual, SOP, or other creative output. Aligned to schema:CreativeWork." ;
    owl:equivalentClass schema:CreativeWork .

:Dataset       a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Dataset" ;
    rdfs:comment "A data collection for ingestion or analysis. Aligned to schema:Dataset." ;
    owl:equivalentClass schema:Dataset .

:SoftwareProject a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Software Project" ;
    rdfs:comment "A software project or repository. BFO:IndependentContinuant." ;
    rdfs:seeAlso schema:SoftwareSourceCode .

# ── Medical Domain Stub (Schema.org) ──
:MedicalEntity a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:label "Medical Entity" ;
    rdfs:comment "A medical concept, condition, or entity. BFO:IndependentContinuant stub for medical domain extension." ;
    rdfs:seeAlso schema:MedicalEntity .

# ── Blue-Collar / Operations Domain ──
:Procedure     a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Procedure" ;
    rdfs:comment "An operational procedure or SOP. BFO:Process, aligned to schema:HowTo." ;
    rdfs:seeAlso schema:HowTo .

# ── Compliance / Regulatory Domain ──
:Regulation    a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Regulation" ;
    rdfs:comment "A compliance or regulatory rule. BFO:GenericallyDependentContinuant." .

# ── Finance Domain (FIBO stubs) ──
:FinancialInstrument a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Financial Instrument" ;
    rdfs:comment "A financial instrument (stock, bond, derivative). BFO:GenericallyDependentContinuant. Aligned to FIBO." ;
    rdfs:seeAlso fibo-fi:FinancialInstrument .

:FinancialTransaction a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Financial Transaction" ;
    rdfs:comment "A financial transaction event. BFO:Process. Aligned to FIBO." .

:Account       a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Account" ;
    rdfs:comment "A financial account. BFO:GenericallyDependentContinuant." .

# =====================================================================
# AHE Classes — Agentic Harness Engineering (CONCEPT:ORCH-1.1)
# =====================================================================

:ChangeManifest a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Change Manifest" ;
    rdfs:comment """A versioned record of harness edits with falsifiable predictions.
BFO:GenericallyDependentContinuant — an information entity that tracks
component-level changes across evolution rounds. wasDerivedFrom is
transitive, enabling automatic lineage tracking across manifests.""" .

:ComponentEditRecord a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Component Edit Record" ;
    rdfs:comment """A granular edit applied to a harness component file.
BFO:GenericallyDependentContinuant — tracks file_path, component_type,
git_commit_sha, predicted_fixes, and predicted_regressions.""" ;
    rdfs:seeAlso prov:Entity .

:EvidenceRecord a owl:Class ;
    rdfs:subClassOf :Evidence ;
    rdfs:label "Evidence Record" ;
    rdfs:comment """Distilled trace evidence from an evaluation round.
Subclass of Evidence — inherits supportsBeliefProp and
contradictsBeliefProp for transitive epistemic reasoning.
Tracks task_id, pass/fail, root_cause, and component attribution.""" .

:ConstraintState a owl:Class ;
    rdfs:subClassOf :Policy ;
    rdfs:label "Constraint State" ;
    rdfs:comment """A hierarchical constraint with enforcement level tracking.
Subclass of Policy — inherits governance semantics. Tracks
current_level (PROMPT→TOOL_DESCRIPTION→MIDDLEWARE→TOOL_IMPLEMENTATION),
violation_count, and escalation history.""" .

# =====================================================================
# Backfill Gap Types — Entities in schema_definition but missing OWL
# =====================================================================

:Task          a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Task" ;
    rdfs:comment """A discrete work unit assigned to an agent. BFO:Process.
Aligned to prov:Activity for provenance tracking (wasGeneratedBy).""" ;
    rdfs:seeAlso prov:Activity .

:Codemap       a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Codemap" ;
    rdfs:comment """A structural representation of a code repository.
BFO:GenericallyDependentContinuant — contains hierarchy, nodes, edges.
partOf transitivity enables multi-level code navigation.""" .

:PatternTemplate a owl:Class ;
    rdfs:subClassOf bfo:0000031 , skos:Concept ;
    rdfs:label "Pattern Template" ;
    rdfs:comment """A reusable solution pattern. BFO:GenericallyDependentContinuant.
Aligned to skos:Concept for broader/narrower taxonomy reasoning.""" .

:ProposedSkill a owl:Class ;
    rdfs:subClassOf :Skill ;
    rdfs:label "Proposed Skill" ;
    rdfs:comment """A candidate skill not yet promoted to production.
Subclass of Skill — inherits all skill properties. wasDerivedFrom
enables tracking skill evolution lineage.""" .

:SystemPromptTemplate a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "System Prompt Template" ;
    rdfs:comment """A versioned system prompt. BFO:GenericallyDependentContinuant.
wasDerivedFrom enables prompt version chain reasoning.""" .

:Prompt        a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Prompt" ;
    rdfs:comment "A prompt template or instruction set. BFO:GenericallyDependentContinuant." .

:ProcessFlow   a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Process Flow" ;
    rdfs:comment """A workflow or process template. BFO:Process.
partOf transitivity enables flow → step → sub-step reasoning.""" .

:ProcessStep   a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Process Step" ;
    rdfs:comment "A step within a ProcessFlow. BFO:Process. partOf ProcessFlow." .

:KnowledgeBase a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Knowledge Base" ;
    rdfs:comment "A curated knowledge collection. BFO:GenericallyDependentContinuant." .

:KnowledgeBaseTopic a owl:Class ;
    rdfs:subClassOf bfo:0000031 , skos:Concept ;
    rdfs:label "Knowledge Base Topic" ;
    rdfs:comment "A topic within a KnowledgeBase. SKOS-aligned for taxonomy reasoning." .

:Experiment    a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Experiment" ;
    rdfs:comment "A self-improvement experiment. BFO:Process." .

# =====================================================================
# Disjointness Axioms
# =====================================================================
:Belief owl:disjointWith :Fact .
:Agent owl:disjointWith :Tool .

# BFO-level disjointness
bfo:0000002 owl:disjointWith bfo:0000003 .

# =====================================================================
# Object Properties — Existing + PROV-O Aligned
# =====================================================================

# ── Existing Properties (preserved) ──
:definedIn     a owl:ObjectProperty ;
    rdfs:domain :Symbol ; rdfs:range :File ;
    rdfs:label "defined in" .

:imports       a owl:ObjectProperty ;
    rdfs:domain :Symbol ; rdfs:range :Symbol ;
    rdfs:label "imports" .

:inheritsFrom  a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :Symbol ; rdfs:range :Symbol ;
    rdfs:label "inherits from" .

:dependsOn     a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:label "depends on" .

:provides      a owl:ObjectProperty ;
    rdfs:domain :Agent ; rdfs:range :Tool ;
    rdfs:label "provides" .

:providedBy    a owl:ObjectProperty ;
    owl:inverseOf :provides ;
    rdfs:label "provided by" .

:partOf        a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:label "part of" .

:contains      a owl:ObjectProperty ;
    owl:inverseOf :partOf ;
    rdfs:label "contains" .

:triggeredBy   a owl:ObjectProperty ;
    rdfs:domain :Event ; rdfs:range :Event ;
    rdfs:label "triggered by" .

:affected      a owl:ObjectProperty ;
    rdfs:domain :Event ;
    rdfs:label "affected" .

:occurredDuring a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :Event ; rdfs:range :Phase ;
    rdfs:label "occurred during" ;
    rdfs:comment "Transitive: if Event occurredDuring Phase and Phase partOf ParentPhase, reasoner can infer Event occurredDuring ParentPhase." .

:supportsBeliefProp a owl:ObjectProperty ;
    rdfs:domain :Evidence ; rdfs:range :Belief ;
    rdfs:label "supports belief" .

:contradictsBeliefProp a owl:ObjectProperty ;
    rdfs:domain :Evidence ; rdfs:range :Belief ;
    rdfs:label "contradicts belief" .

:ownedBy       a owl:ObjectProperty ;
    rdfs:domain :System ; rdfs:range :Organization ;
    rdfs:label "owned by" .

:hasRole       a owl:ObjectProperty ;
    rdfs:domain :Person ; rdfs:range :Role ;
    rdfs:label "has role" .

:motivatedBy   a owl:ObjectProperty ;
    rdfs:domain :Decision ; rdfs:range :Goal ;
    rdfs:label "motivated by" .

:producedOutcome a owl:ObjectProperty ;
    rdfs:domain :Episode ; rdfs:range :OutcomeEvaluation ;
    rdfs:label "produced outcome" .

:triggeredAction a owl:ObjectProperty ;
    rdfs:domain :Event ; rdfs:range :Action ;
    rdfs:label "triggered action" .

:observedBy    a owl:ObjectProperty ;
    rdfs:domain :Observation ; rdfs:range :Agent ;
    rdfs:label "observed by" .

# ── NEW: PROV-O Provenance Properties ──
:wasGeneratedBy a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasGeneratedBy ;
    rdfs:label "was generated by" ;
    rdfs:comment "Provenance: what Activity generated this Entity." .

:wasDerivedFrom a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    rdfs:label "was derived from" ;
    rdfs:comment "Provenance: transitive entity derivation chain." .

:wasAttributedTo a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasAttributedTo ;
    rdfs:label "was attributed to" ;
    rdfs:comment "Provenance: who is responsible for this entity." .

# ── NEW: SKOS Taxonomy Properties (Full Support) ──
:broader a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:subPropertyOf skos:broader ;
    rdfs:label "broader" ;
    rdfs:comment "SKOS broader relationship — transitive concept hierarchy." .

:narrower a owl:ObjectProperty ;
    owl:inverseOf :broader ;
    rdfs:subPropertyOf skos:narrower ;
    rdfs:label "narrower" ;
    rdfs:comment "SKOS narrower relationship — inverse of broader." .

:related a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:subPropertyOf skos:related ;
    rdfs:label "related" ;
    rdfs:comment "SKOS associative relationship — symmetric." .

:exactMatch a owl:ObjectProperty, owl:SymmetricProperty, owl:TransitiveProperty ;
    rdfs:subPropertyOf skos:exactMatch ;
    rdfs:label "exact match" ;
    rdfs:comment "SKOS exact concept match across vocabularies." .

:closeMatch a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:subPropertyOf skos:closeMatch ;
    rdfs:label "close match" ;
    rdfs:comment "SKOS close concept match across vocabularies." .

:broadMatch a owl:ObjectProperty ;
    rdfs:subPropertyOf skos:broadMatch ;
    rdfs:label "broad match" ;
    rdfs:comment "SKOS broad match across vocabularies." .

# ── NEW: Dublin Core Metadata Properties ──
:creator a owl:ObjectProperty ;
    rdfs:subPropertyOf dc:creator ;
    rdfs:label "creator" ;
    rdfs:comment "Dublin Core: entity that created this resource." .

:citesSource a owl:ObjectProperty ;
    rdfs:label "cites source" ;
    rdfs:comment "Links a document or article to its cited source." ;
    rdfs:seeAlso dc:references .

# ── NEW: Temporal Properties (OWL-Time aligned) ──
:hasTemporalExtent a owl:ObjectProperty ;
    rdfs:label "has temporal extent" ;
    rdfs:comment "Links an entity to its temporal extent. Aligned to time:hasTime." ;
    rdfs:seeAlso time:hasTime .

# ── NEW: Finance Domain Properties ──
:hasFinancialInstrument a owl:ObjectProperty ;
    rdfs:domain :Account ; rdfs:range :FinancialInstrument ;
    rdfs:label "has financial instrument" .

:executedTransaction a owl:ObjectProperty ;
    rdfs:domain :Agent ; rdfs:range :FinancialTransaction ;
    rdfs:label "executed transaction" .

# ── NEW: AHE Object Properties (CONCEPT:ORCH-1.1) ──
:editedInRound a owl:ObjectProperty ;
    rdfs:domain :ComponentEditRecord ; rdfs:range :ChangeManifest ;
    rdfs:label "edited in round" ;
    rdfs:comment "Links a component edit to its parent evolution round manifest." .

:predictedFix  a owl:ObjectProperty ;
    rdfs:domain :ComponentEditRecord ; rdfs:range :Task ;
    rdfs:label "predicted fix" ;
    rdfs:comment "Falsifiable: this edit is predicted to fix this task." .

:causedRegression a owl:ObjectProperty ;
    rdfs:domain :ComponentEditRecord ; rdfs:range :Task ;
    rdfs:label "caused regression" ;
    rdfs:comment "Verified: this edit caused this task to regress." .

:confirmedFix  a owl:ObjectProperty ;
    rdfs:domain :ComponentEditRecord ; rdfs:range :Task ;
    rdfs:label "confirmed fix" ;
    rdfs:comment "Verified: this edit confirmed to fix this task." .

:verifiedBy    a owl:ObjectProperty ;
    rdfs:domain :ChangeManifest ;
    rdfs:label "verified by" ;
    rdfs:comment "Links a manifest to its verification evidence." .

:escalatedTo   a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :ConstraintState ; rdfs:range :ConstraintState ;
    rdfs:label "escalated to" ;
    rdfs:comment "Constraint escalation chain. Transitive: if A escalated to B and B escalated to C, reasoner infers A escalated to C." .

:appliedEdit   a owl:ObjectProperty ;
    rdfs:domain :ChangeManifest ; rdfs:range :ComponentEditRecord ;
    rdfs:label "applied edit" ;
    rdfs:comment "Links a manifest to its component edits." .

:hasEditFor    a owl:ObjectProperty ;
    owl:inverseOf :editedInRound ;
    rdfs:label "has edit for" ;
    rdfs:comment "Inverse: manifest → component edit." .

# =====================================================================
# Datatype Properties — Existing + Dublin Core + PROV-O + AHE
# =====================================================================
:confidence    a owl:DatatypeProperty ; rdfs:range xsd:float .
:importance    a owl:DatatypeProperty ; rdfs:range xsd:float .
:severity      a owl:DatatypeProperty ; rdfs:range xsd:string .
:timestamp     a owl:DatatypeProperty ; rdfs:range xsd:dateTime .

# ── NEW: PROV-O Temporal Datatype Properties ──
:startedAtTime a owl:DatatypeProperty ;
    rdfs:subPropertyOf prov:startedAtTime ;
    rdfs:range xsd:dateTime ;
    rdfs:label "started at time" .

:endedAtTime   a owl:DatatypeProperty ;
    rdfs:subPropertyOf prov:endedAtTime ;
    rdfs:range xsd:dateTime ;
    rdfs:label "ended at time" .

# ── NEW: Dublin Core Datatype Properties ──
:title         a owl:DatatypeProperty ;
    rdfs:subPropertyOf dc:title ;
    rdfs:range xsd:string ;
    rdfs:label "title" .

:subject       a owl:DatatypeProperty ;
    rdfs:subPropertyOf dc:subject ;
    rdfs:range xsd:string ;
    rdfs:label "subject" .

:identifier    a owl:DatatypeProperty ;
    rdfs:subPropertyOf dc:identifier ;
    rdfs:range xsd:string ;
    rdfs:label "identifier" ;
    rdfs:comment "Dublin Core identifier — DOI, ISBN, URN, etc." .

:dateCreated   a owl:DatatypeProperty ;
    rdfs:subPropertyOf dc:date ;
    rdfs:range xsd:dateTime ;
    rdfs:label "date created" .

:language      a owl:DatatypeProperty ;
    rdfs:subPropertyOf dc:language ;
    rdfs:range xsd:string ;
    rdfs:label "language" .

:format        a owl:DatatypeProperty ;
    rdfs:subPropertyOf dc:format ;
    rdfs:range xsd:string ;
    rdfs:label "format" ;
    rdfs:comment "MIME type or file format." .

# ── NEW: SKOS Taxonomy Datatype Properties ──
:prefLabel     a owl:DatatypeProperty ;
    rdfs:subPropertyOf skos:prefLabel ;
    rdfs:range xsd:string ;
    rdfs:label "preferred label" .

:altLabel      a owl:DatatypeProperty ;
    rdfs:subPropertyOf skos:altLabel ;
    rdfs:range xsd:string ;
    rdfs:label "alternative label" .

:notation      a owl:DatatypeProperty ;
    rdfs:subPropertyOf skos:notation ;
    rdfs:range xsd:string ;
    rdfs:label "notation" ;
    rdfs:comment "SKOS notation — a code or identifier for a concept in a classification scheme." .

# ── NEW: AHE Datatype Properties (CONCEPT:ORCH-1.1) ──
:baselineScore a owl:DatatypeProperty ;
    rdfs:domain :ChangeManifest ; rdfs:range xsd:float ;
    rdfs:label "baseline score" ;
    rdfs:comment "Benchmark score before this evolution round." .

:predictedScore a owl:DatatypeProperty ;
    rdfs:domain :ChangeManifest ; rdfs:range xsd:float ;
    rdfs:label "predicted score" ;
    rdfs:comment "Falsifiable: predicted score after applying edits." .

:actualScore   a owl:DatatypeProperty ;
    rdfs:domain :ChangeManifest ; rdfs:range xsd:float ;
    rdfs:label "actual score" ;
    rdfs:comment "Actual benchmark score measured after edits." .

:currentLevel  a owl:DatatypeProperty ;
    rdfs:domain :ConstraintState ; rdfs:range xsd:string ;
    rdfs:label "current level" ;
    rdfs:comment "Current enforcement level: PROMPT, TOOL_DESCRIPTION, MIDDLEWARE, or TOOL_IMPLEMENTATION." .

:violationCount a owl:DatatypeProperty ;
    rdfs:domain :ConstraintState ; rdfs:range xsd:integer ;
    rdfs:label "violation count" ;
    rdfs:comment "Number of times this constraint has been violated." .

# =====================================================================
# Agentic Design Patterns Gap Classes (CONCEPT:ORCH-1.1 through CONCEPT:AHE-3.2)
# =====================================================================

# ── CONCEPT:ORCH-1.1: Prompt Chaining ──
:PromptChain   a owl:Class ;
    rdfs:subClassOf :Procedure ;
    rdfs:label "Prompt Chain" ;
    rdfs:comment "A declarative multi-step prompt pipeline with intermediate validation and conditional branching. BFO:Process via Procedure." .

:PromptChainStep a owl:Class ;
    rdfs:subClassOf :Action ;
    rdfs:label "Prompt Chain Step" ;
    rdfs:comment "A single step within a PromptChain. BFO:Process via Action." .

# ── CONCEPT:OS-5.2: Resource-Aware Optimization ──
:ResourceUsage a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Resource Usage Record" ;
    rdfs:comment "Per-session resource consumption tracking (tokens, cost, latency). BFO:Process." .

# ── CONCEPT:AHE-3.1: Evaluation & Monitoring ──
:EvaluationRecord a owl:Class ;
    rdfs:subClassOf :Observation ;
    rdfs:label "Multi-Dimensional Evaluation Record" ;
    rdfs:comment "Multi-dimensional quality evaluation with per-dimension scoring. Subclass of Observation." .

# ── CONCEPT:ORCH-1.1: Task Prioritization ──
:PrioritizedTask a owl:Class ;
    rdfs:subClassOf :Action ;
    rdfs:label "Prioritized Task" ;
    rdfs:comment "A task with multi-factor priority scoring (urgency, impact, effort, risk). BFO:Process via Action." .

# ── CONCEPT:AHE-3.2: Exploration & Discovery ──
:KnowledgeGap  a owl:Class ;
    rdfs:subClassOf :Observation ;
    rdfs:label "Knowledge Gap" ;
    rdfs:comment "An identified gap in the agent's knowledge. Subclass of Observation." .

:ExplorationExperiment a owl:Class ;
    rdfs:subClassOf :Procedure ;
    rdfs:label "Exploration Experiment" ;
    rdfs:comment "A structured experiment to test a hypothesis. BFO:Process via Procedure." .

# =====================================================================
# Object Properties — CONCEPT:ORCH-1.1 through CONCEPT:AHE-3.2
# =====================================================================

# ── CONCEPT:ORCH-1.1 ──
:hasChainStep  a owl:ObjectProperty ;
    rdfs:domain :PromptChain ; rdfs:range :PromptChainStep ;
    rdfs:label "has chain step" .

:branchesTo    a owl:ObjectProperty ;
    rdfs:domain :PromptChainStep ; rdfs:range :PromptChainStep ;
    rdfs:label "branches to" .

# ── CONCEPT:OS-5.2 ──
:consumedResource a owl:ObjectProperty ;
    rdfs:domain :Episode ; rdfs:range :ResourceUsage ;
    rdfs:label "consumed resource" .

# ── CONCEPT:AHE-3.1 ──
:evaluatedWith a owl:ObjectProperty ;
    rdfs:domain :Episode ; rdfs:range :EvaluationRecord ;
    rdfs:label "evaluated with" .

:calibratedAgainst a owl:ObjectProperty ;
    rdfs:domain :EvaluationRecord ; rdfs:range :EvaluationRecord ;
    rdfs:label "calibrated against" ;
    rdfs:comment "Links a machine evaluation to a human calibration baseline." .

# ── CONCEPT:ORCH-1.1 ──
:blocksProp    a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :PrioritizedTask ; rdfs:range :PrioritizedTask ;
    rdfs:label "blocks" ;
    rdfs:comment "Transitive: if A blocks B and B blocks C, A indirectly blocks C." .

:assignedToSpecialist a owl:ObjectProperty ;
    rdfs:domain :PrioritizedTask ; rdfs:range :Agent ;
    rdfs:label "assigned to specialist" .

:hasPriority   a owl:DatatypeProperty ;
    rdfs:domain :PrioritizedTask ; rdfs:range xsd:float ;
    rdfs:label "has priority" ;
    rdfs:comment "Composite priority score (0.0–1.0)." .

# ── CONCEPT:AHE-3.2 ──
:testsHypothesis a owl:ObjectProperty ;
    rdfs:domain :ExplorationExperiment ; rdfs:range :Hypothesis ;
    rdfs:label "tests hypothesis" .

:exploredGap   a owl:ObjectProperty ;
    rdfs:domain :Hypothesis ; rdfs:range :KnowledgeGap ;
    rdfs:label "explored gap" .

:resultedInDiscovery a owl:ObjectProperty ;
    rdfs:domain :ExplorationExperiment ; rdfs:range :Fact ;
    rdfs:label "resulted in discovery" .

# =====================================================================
# Datatype Properties — CONCEPT:OS-5.2, CONCEPT:AHE-3.1
# =====================================================================

:hasResourceEfficiency a owl:DatatypeProperty ;
    rdfs:domain :Agent ; rdfs:range xsd:float ;
    rdfs:label "has resource efficiency" ;
    rdfs:comment "Composite resource efficiency metric for model selection optimization." .

:correctnessScore a owl:DatatypeProperty ;
    rdfs:domain :EvaluationRecord ; rdfs:range xsd:float ;
    rdfs:label "correctness score" .

:completenessScore a owl:DatatypeProperty ;
    rdfs:domain :EvaluationRecord ; rdfs:range xsd:float ;
    rdfs:label "completeness score" .

:relevanceScore a owl:DatatypeProperty ;
    rdfs:domain :EvaluationRecord ; rdfs:range xsd:float ;
    rdfs:label "relevance score" .

:safetyScore   a owl:DatatypeProperty ;
    rdfs:domain :EvaluationRecord ; rdfs:range xsd:float ;
    rdfs:label "safety score" .

# =====================================================================
# Engineering Rules Engine (CONCEPT:KG-2.2)
# Agent-rules-books integration for context-sensitive rule retrieval
# =====================================================================

# ── CONCEPT:KG-2.2: Core Classes ──
:EngineeringRule a owl:Class ;
    rdfs:subClassOf :Principle ;
    rdfs:label "Engineering Rule" ;
    rdfs:comment """A software engineering rule derived from a canonical book.
Subclass of Principle — inherits strength, scope, and derivation semantics.
Adds tier (full/mini/nano), rule classification, bias correction tracking,
and AHE efficacy scoring for evolutionary rule selection.""" .

:RuleBook a owl:Class ;
    rdfs:subClassOf :CreativeWork ;
    rdfs:label "Rule Book" ;
    rdfs:comment """A canonical software engineering book that is the source
of engineering rules (e.g., 'Clean Architecture', 'Domain-Driven Design').
Subclass of CreativeWork for Dublin Core / BIBO alignment.""" .

# ── CONCEPT:KG-2.2: Object Properties ──
:correctsBias  a owl:ObjectProperty ;
    rdfs:domain :EngineeringRule ;
    rdfs:label "corrects bias" ;
    rdfs:comment "Links a rule to the LLM bias pattern it prevents." .

:applicableWhen a owl:ObjectProperty ;
    rdfs:domain :EngineeringRule ; rdfs:range :Concept ;
    rdfs:label "applicable when" ;
    rdfs:comment "Links a rule to the task context Concept where it activates." .

:conflictsWith a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain :EngineeringRule ; rdfs:range :EngineeringRule ;
    rdfs:label "conflicts with" ;
    rdfs:comment """Symmetric: if Rule A conflicts with Rule B, then B conflicts
with A. Conflict resolution uses deterministic conflict_weight comparison.""" .

:derivedFromBook a owl:ObjectProperty ;
    rdfs:domain :EngineeringRule ; rdfs:range :RuleBook ;
    rdfs:label "derived from book" ;
    rdfs:comment "Links a rule to its source book for provenance tracking." .

:appliedInTask a owl:ObjectProperty ;
    rdfs:domain :EngineeringRule ; rdfs:range :Task ;
    rdfs:label "applied in task" ;
    rdfs:comment "Links a rule to tasks where it was active for AHE tracking." .

# ── CONCEPT:KG-2.2: Datatype Properties ──
:ruleTier      a owl:DatatypeProperty ;
    rdfs:domain :EngineeringRule ; rdfs:range xsd:string ;
    rdfs:label "rule tier" ;
    rdfs:comment "Context-budget tier: full, mini, or nano." .

:ruleClass     a owl:DatatypeProperty ;
    rdfs:domain :EngineeringRule ; rdfs:range xsd:string ;
    rdfs:label "rule class" ;
    rdfs:comment "Classification: book-thesis, decision-changing, micro-decision, trigger, conflict-resolver, checklist-only, framing, default." .

:efficacyScore a owl:DatatypeProperty ;
    rdfs:domain :EngineeringRule ; rdfs:range xsd:float ;
    rdfs:label "efficacy score" ;
    rdfs:comment "Running efficacy score from AHE feedback (0.0–1.0)." .

:conflictWeight a owl:DatatypeProperty ;
    rdfs:domain :EngineeringRule ; rdfs:range xsd:float ;
    rdfs:label "conflict weight" ;
    rdfs:comment "Deterministic weight for cross-book conflict resolution (0.0–1.0)." .

:applicationCount a owl:DatatypeProperty ;
    rdfs:domain :EngineeringRule ; rdfs:range xsd:integer ;
    rdfs:label "application count" ;
    rdfs:comment "Number of times this rule has been applied." .

:violationCount a owl:DatatypeProperty ;
    rdfs:domain :EngineeringRule ; rdfs:range xsd:integer ;
    rdfs:label "violation count" ;
    rdfs:comment "Number of times this rule was violated." .

# =====================================================================
# External Integration & SDLC Entities (CONCEPT:ORCH-1.2)
# =====================================================================

# ── SDLC Core Classes ──
:Repository a owl:Class ;
    rdfs:subClassOf :SoftwareProject ;
    rdfs:label "Repository" ;
    rdfs:comment "A source code repository (e.g. GitHub, GitLab)." .

:MergeRequest a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Merge Request" ;
    rdfs:comment "A merge request or pull request. BFO:Process." .

:PullRequest a owl:Class ;
    owl:equivalentClass :MergeRequest ;
    rdfs:label "Pull Request" .

:Pipeline a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Pipeline" ;
    rdfs:comment "A CI/CD pipeline run. BFO:Process." .

:Commit a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Commit" ;
    rdfs:comment "A version control commit. BFO:GenericallyDependentContinuant." .

:Issue a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Issue" ;
    rdfs:comment "A project management issue or ticket." .

# ── External Knowledge Graph Classes ──
:ExternalGraphReference a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "External Graph Reference" ;
    rdfs:comment "A reference to an external Knowledge Graph (e.g., LeanIX)." .

:ExternalEntity a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "External Entity" ;
    rdfs:comment "A stub entity representing a node in an external Knowledge Graph." .

# ── Object Properties ──
:modifiedIn a owl:ObjectProperty ;
    rdfs:label "modified in" ;
    rdfs:comment "Links a File or Symbol to the Commit that modified it." .

:mentionedIn a owl:ObjectProperty ;
    rdfs:label "mentioned in" ;
    rdfs:comment "Links an entity to an Issue or MergeRequest where it is mentioned." .

:triggered a owl:ObjectProperty ;
    rdfs:label "triggered" ;
    rdfs:comment "Links a MergeRequest or Commit to the Pipeline it triggered." .

:targets a owl:ObjectProperty ;
    rdfs:label "targets" ;
    rdfs:comment "Links a MergeRequest to its target Repository." .

:mappedToExternal a owl:ObjectProperty ;
    rdfs:label "mapped to external" ;
    rdfs:comment "Links an internal node to an ExternalEntity stub." .

# ── Datatype Properties ──
:sourceUrl a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "source url" .

:platform a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "platform" .

:state a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "state" .

:sha a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "sha" .

:message a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "message" .

:status a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "status" .

:externalUri a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "external uri" .

:externalSystemId a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "external system id" .

# ══════════════════════════════════════════════════════════════════════
# Financial Trading Pipeline (CONCEPT:KG-2.6)
# ══════════════════════════════════════════════════════════════════════

:TradingSignal a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "A buy/sell/hold signal with confidence and attribution." ;
    rdfs:label "trading signal" .

:Order a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "An order in the trading pipeline lifecycle." ;
    rdfs:label "order" .

:Position a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "An open or closed position in a portfolio." ;
    rdfs:label "position" .

:Portfolio a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "An aggregation of positions with allocation tracking." ;
    rdfs:label "portfolio" .

:Strategy a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "A named trading strategy with parameters and performance lineage." ;
    rdfs:label "strategy" .

:generatedSignal a owl:ObjectProperty ;
    rdfs:domain :Strategy ;
    rdfs:range :TradingSignal ;
    rdfs:label "generated signal" .

:placedOrder a owl:ObjectProperty ;
    rdfs:domain :TradingSignal ;
    rdfs:range :Order ;
    rdfs:label "placed order" .

:openedPosition a owl:ObjectProperty ;
    rdfs:domain :Order ;
    rdfs:range :Position ;
    rdfs:label "opened position" .

:belongsToPortfolio a owl:ObjectProperty ;
    rdfs:domain :Position ;
    rdfs:range :Portfolio ;
    rdfs:label "belongs to portfolio" .

:executesStrategy a owl:ObjectProperty ;
    rdfs:domain :Portfolio ;
    rdfs:range :Strategy ;
    rdfs:label "executes strategy" .

:backtestedWith a owl:ObjectProperty ;
    rdfs:domain :Strategy ;
    rdfs:range :BacktestRun ;
    rdfs:label "backtested with" .

# Trading pipeline datatype properties
:signalType a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "signal type" .

:entryPrice a owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "entry price" .

:exitPrice a owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "exit price" .

:pnl a owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "profit and loss" .

:sharpeRatio a owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "sharpe ratio" .

:maxDrawdown a owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "maximum drawdown" .

# ══════════════════════════════════════════════════════════════════════
# Market Data Connector Protocol (CONCEPT:ECO-4.4)
# ══════════════════════════════════════════════════════════════════════

:DataConnector a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "A registered external data source with health and rate-limit metadata." ;
    rdfs:label "data connector" .

:DataFetchRecord a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "Immutable provenance record of a data fetch operation." ;
    rdfs:label "data fetch record" .

:fetchedFrom a owl:ObjectProperty ;
    rdfs:domain :DataFetchRecord ;
    rdfs:range :DataConnector ;
    rdfs:label "fetched from" .

:fallsBackTo a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :DataConnector ;
    rdfs:range :DataConnector ;
    rdfs:comment "Transitive fallback chain. If A fallsBackTo B and B fallsBackTo C, then A fallsBackTo C." ;
    rdfs:label "falls back to" .

# ══════════════════════════════════════════════════════════════════════
# Swarm Preset Template Engine (CONCEPT:ORCH-1.4)
# ══════════════════════════════════════════════════════════════════════

:SwarmPreset a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "A declarative multi-agent workflow preset stored in the KG." ;
    rdfs:label "swarm preset" .

:SwarmRun a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "Execution record of a swarm preset run." ;
    rdfs:label "swarm run" .

:SwarmTaskRecord a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "Individual task execution record within a swarm run." ;
    rdfs:label "swarm task record" .

:presetOf a owl:ObjectProperty ;
    rdfs:domain :SwarmPreset ;
    rdfs:range :TeamConfig ;
    rdfs:label "preset of" .

:ranPreset a owl:ObjectProperty ;
    rdfs:domain :SwarmRun ;
    rdfs:range :SwarmPreset ;
    rdfs:label "ran preset" .

:taskDependsOn a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :SwarmTaskRecord ;
    rdfs:range :SwarmTaskRecord ;
    rdfs:comment "DAG dependency between tasks. Transitive for indirect dependencies." ;
    rdfs:label "task depends on" .

# ══════════════════════════════════════════════════════════════════════
# Risk Scoring Ontology (CONCEPT:KG-2.7)
# ══════════════════════════════════════════════════════════════════════

:RiskAssessment a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "Domain-agnostic risk evaluation with multi-dimensional scoring." ;
    rdfs:label "risk assessment" .

:RiskFactor a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "An individual risk factor contributing to an assessment." ;
    rdfs:label "risk factor" .

:RiskMitigation a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "A proposed or applied mitigation for a risk factor." ;
    rdfs:label "risk mitigation" .

:assessedRisk a owl:ObjectProperty ;
    rdfs:range :RiskAssessment ;
    rdfs:comment "Links any entity to its risk assessment." ;
    rdfs:label "assessed risk" .

:hasRiskFactor a owl:ObjectProperty ;
    rdfs:domain :RiskAssessment ;
    rdfs:range :RiskFactor ;
    rdfs:label "has risk factor" .

:mitigatedBy a owl:ObjectProperty ;
    rdfs:domain :RiskFactor ;
    rdfs:range :RiskMitigation ;
    rdfs:label "mitigated by" .

:propagatesRiskTo a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:comment "Transitive risk propagation. If A propagatesRiskTo B and B propagatesRiskTo C, then A propagatesRiskTo C. Enables automated upstream risk chain inference via OWL reasoning." ;
    rdfs:label "propagates risk to" .

:hasSeverityScore a owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "severity score" .

# ══════════════════════════════════════════════════════════════════════
# Backtest Evaluation Harness (CONCEPT:AHE-3.8)
# ══════════════════════════════════════════════════════════════════════

:BacktestRun a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "A complete backtesting or evaluation run record." ;
    rdfs:label "backtest run" .

:BacktestMetric a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "An individual metric from a backtest or evaluation run." ;
    rdfs:label "backtest metric" .

:evaluatedStrategy a owl:ObjectProperty ;
    rdfs:domain :BacktestRun ;
    rdfs:range :Strategy ;
    rdfs:label "evaluated strategy" .

:hasMetric a owl:ObjectProperty ;
    rdfs:domain :BacktestRun ;
    rdfs:range :BacktestMetric ;
    rdfs:label "has metric" .

:comparedToBenchmark a owl:ObjectProperty ;
    rdfs:domain :BacktestRun ;
    rdfs:comment "Benchmark comparison reference." ;
    rdfs:label "compared to benchmark" .

# ══════════════════════════════════════════════════════════════════════
# Agentic-iModels (CONCEPT:AHE-3.15, AHE-3.16, KG-2.17)
# arXiv:2605.03808 — Agent-interpretable ML model evolution
# ══════════════════════════════════════════════════════════════════════

:IModel a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "An evolved agent-interpretable ML model class with dual-axis fitness (accuracy + LLM readability). Based on arXiv:2605.03808." ;
    rdfs:label "interpretable model" .

:InterpretabilityTest a owl:Class ;
    rdfs:subClassOf :EvaluationRecord ;
    rdfs:comment "A quantitative test result measuring whether an LLM can simulate model predictions from __str__() output alone." ;
    rdfs:label "interpretability test" .

:ModelDisplay a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "An optimized display representation of a model's __str__() output, decoupled from predict() logic." ;
    rdfs:label "model display" .

:ParetoFrontierEntry a owl:Class ;
    rdfs:subClassOf :RegistryNode ;
    rdfs:comment "A model on the Pareto frontier of accuracy vs interpretability." ;
    rdfs:label "pareto frontier entry" .

:evolvedModel a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :IModel ;
    rdfs:range :IModel ;
    rdfs:comment "Transitive evolutionary lineage. If model A evolvedModel B and B evolvedModel C, then A evolvedModel C." ;
    rdfs:label "evolved model" .

:testedInterpretability a owl:ObjectProperty ;
    rdfs:domain :IModel ;
    rdfs:range :InterpretabilityTest ;
    rdfs:label "tested interpretability" .

:displayOf a owl:ObjectProperty ;
    rdfs:domain :ModelDisplay ;
    rdfs:range :IModel ;
    rdfs:label "display of" .

:paretoDominates a owl:ObjectProperty ;
    rdfs:domain :IModel ;
    rdfs:range :IModel ;
    rdfs:comment "Links a dominating model to a dominated model on both accuracy and interpretability axes." ;
    rdfs:label "pareto dominates" .

:interpretabilityScore a owl:DatatypeProperty ;
    rdfs:domain :IModel ;
    rdfs:range xsd:float ;
    rdfs:comment "Agent interpretability pass rate (0.0-1.0) from LLM-graded tests." ;
    rdfs:label "interpretability score" .

:predictiveRank a owl:DatatypeProperty ;
    rdfs:domain :IModel ;
    rdfs:range xsd:float ;
    rdfs:comment "Normalized RMSE rank across datasets (0.0=best, 1.0=worst)." ;
    rdfs:label "predictive rank" .

:displayStrategy a owl:DatatypeProperty ;
    rdfs:domain :ModelDisplay ;
    rdfs:range xsd:string ;
    rdfs:comment "Display optimization strategy: linear_collapse, piecewise_table, symbolic_equation, coefficient_summary, adaptive." ;
    rdfs:label "display strategy" .

# ============================================================================
# Ecosystem Topology Map (CONCEPT:ECO-4.7)
# ============================================================================

# --- Ecosystem Package Hierarchy ---

:EcosystemPackage a owl:Class ;
    rdfs:subClassOf bfo:0000004 ;
    rdfs:comment "A software package within the agent-utilities ecosystem." ;
    rdfs:label "Ecosystem Package" .

:KernelPackage a owl:Class ;
    rdfs:subClassOf :EcosystemPackage ;
    rdfs:comment "The core agent-utilities kernel package." ;
    rdfs:label "Kernel Package" .

:FrontendPackage a owl:Class ;
    rdfs:subClassOf :EcosystemPackage ;
    rdfs:comment "A user-facing frontend (TUI or WebUI) package." ;
    rdfs:label "Frontend Package" .

:MCPServerPackage a owl:Class ;
    rdfs:subClassOf :EcosystemPackage ;
    rdfs:comment "An MCP server package providing tool integrations." ;
    rdfs:label "MCP Server Package" .

:SkillPackage a owl:Class ;
    rdfs:subClassOf :EcosystemPackage ;
    rdfs:comment "A package providing skill definitions or skill graphs." ;
    rdfs:label "Skill Package" .

# --- MCP Server Category Subclasses ---

:InfrastructureMCP a owl:Class ;
    rdfs:subClassOf :MCPServerPackage ;
    rdfs:comment "MCP server for infrastructure management (containers, tunnels, etc.)." ;
    rdfs:label "Infrastructure MCP" .

:MediaMCP a owl:Class ;
    rdfs:subClassOf :MCPServerPackage ;
    rdfs:comment "MCP server for media services (Jellyfin, audio, etc.)." ;
    rdfs:label "Media MCP" .

:ProductivityMCP a owl:Class ;
    rdfs:subClassOf :MCPServerPackage ;
    rdfs:comment "MCP server for productivity tools (Atlassian, Nextcloud, etc.)." ;
    rdfs:label "Productivity MCP" .

:DataScienceMCP a owl:Class ;
    rdfs:subClassOf :MCPServerPackage ;
    rdfs:comment "MCP server for data science workflows." ;
    rdfs:label "Data Science MCP" .

:DevOpsMCP a owl:Class ;
    rdfs:subClassOf :MCPServerPackage ;
    rdfs:comment "MCP server for DevOps tooling (GitHub, GitLab, CI/CD)." ;
    rdfs:label "DevOps MCP" .

:CommunicationMCP a owl:Class ;
    rdfs:subClassOf :MCPServerPackage ;
    rdfs:comment "MCP server for communication platforms (Microsoft, etc.)." ;
    rdfs:label "Communication MCP" .

# --- Ecosystem Properties ---

:providesCapabilityTo a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :EcosystemPackage ;
    rdfs:range :EcosystemPackage ;
    rdfs:comment "A package provides capability to another package (transitive)." ;
    rdfs:label "provides capability to" .

:consumesFromKernel a owl:ObjectProperty ;
    rdfs:domain :EcosystemPackage ;
    rdfs:range :KernelPackage ;
    rdfs:comment "A package consumes services from the kernel package." ;
    rdfs:label "consumes from kernel" .

:visualizes a owl:ObjectProperty ;
    rdfs:domain :FrontendPackage ;
    rdfs:range owl:Thing ;
    rdfs:comment "A frontend package visualizes data from another entity." ;
    rdfs:label "visualizes" .

:hasSynergyWith a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain :EcosystemPackage ;
    rdfs:range :EcosystemPackage ;
    rdfs:comment "CONCEPT:KG-2.19 — Two packages have a discovered functional synergy." ;
    rdfs:label "has synergy with" .

:packageCategory a owl:DatatypeProperty ;
    rdfs:domain :EcosystemPackage ;
    rdfs:range xsd:string ;
    rdfs:comment "Intelligent category classification: infrastructure, media, productivity, data_science, devops, communication." ;
    rdfs:label "package category" .

:packageVersion a owl:DatatypeProperty ;
    rdfs:domain :EcosystemPackage ;
    rdfs:range xsd:string ;
    rdfs:label "package version" .
