@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix bfo: <http://purl.obolibrary.org/obo/BFO_> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://knuckles.team/kg> a owl:Ontology ;
    rdfs:label "Agent Intelligence Graph Ontology" ;
    rdfs:comment """Formal OWL ontology for the Unified Intelligence Graph.
Provides BFO-aligned upper ontology classification, industry-standard vocabulary
mappings (PROV-O, Schema.org, Dublin Core, FOAF, SKOS, OWL-Time, BIBO, FIBO),
transitive/subclass/inverse-property reasoning, and full SKOS taxonomy support
over stable LPG data.

This is the SINGLE canonical ontology. It imports EVERY bundled domain module
(one owl:imports edge per ontology_<module>.ttl), so the owl:imports federation
index and the file set the loader/publisher glob stay in lockstep — there are no
unlinked domain ontologies. Adding a new domain ontology means adding its file AND
an import edge here; scripts/check_ontology.py enforces both. See
docs/architecture/ontology_library.md for the full module catalog and roles.""" ;
    owl:imports <http://knuckles.team/kg/a2a>,
        <http://knuckles.team/kg/action>,
        <http://knuckles.team/kg/archimate>,
        <http://knuckles.team/kg/banking>,
        <http://knuckles.team/kg/calendar>,
        <http://knuckles.team/kg/capability>,
        <http://knuckles.team/kg/company>,
        <http://knuckles.team/kg/company_infra>,
        <http://knuckles.team/kg/database>,
        <http://knuckles.team/kg/egeria>,
        <http://knuckles.team/kg/energy_geopolitics>,
        <http://knuckles.team/kg/enterprise>,
        <http://knuckles.team/kg/erpnext>,
        <http://knuckles.team/kg/feed>,
        <http://knuckles.team/kg/government>,
        <http://knuckles.team/kg/grafana>,
        <http://knuckles.team/kg/harness>,
        <http://knuckles.team/kg/hr>,
        <http://knuckles.team/kg/identity>,
        <http://knuckles.team/kg/leanix>,
        <http://knuckles.team/kg/legal>,
        <http://knuckles.team/kg/media>,
        <http://knuckles.team/kg/medical>,
        <http://knuckles.team/kg/observability>,
        <http://knuckles.team/kg/orchestration>,
        <http://knuckles.team/kg/personal>,
        <http://knuckles.team/kg/quant>,
        <http://knuckles.team/kg/sdd>,
        <http://knuckles.team/kg/servicenow>,
        <http://knuckles.team/kg/social>,
        <http://knuckles.team/kg/software>,
        <http://knuckles.team/kg/system>,
        <http://knuckles.team/kg/trading>,
        <http://knuckles.team/kg/trm>,
        <http://knuckles.team/kg/wellness>,
        <https://agent-utilities.dev/ontology/infrastructure> .

:Agreement a owl:Class ;
    rdfs:label "Agreement" ;
    rdfs:comment "Sources corroborated by two or more perspectives — likely true (CONCEPT:KG-2.128)." ;
    rdfs:subClassOf :Concept .

:BeliefInterval a owl:Class ;
    rdfs:label "Belief Interval" ;
    rdfs:comment "The transaction-time window during which the engine BELIEVED a fact (PROV generated→invalidated)." ;
    rdfs:subClassOf time:Interval .

:BlindSpot a owl:Class ;
    rdfs:label "Blind Spot" ;
    rdfs:comment "Topic neighbourhood no perspective's questions covered (CONCEPT:KG-2.128)." ;
    rdfs:subClassOf :Concept .

:Contradiction a owl:Class ;
    rdfs:label "Contradiction" ;
    rdfs:comment "Two perspectives that surfaced non-overlapping evidence (CONCEPT:KG-2.128)." ;
    rdfs:subClassOf :Concept .

:CreativeWork a owl:Class ;
    rdfs:label "Creative Work" ;
    rdfs:comment "A book, manual, SOP, or other creative output. Aligned to schema:CreativeWork." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :createdBy ;
            owl:someValuesFrom bfo:0000004 ],
        bfo:0000031 ;
    owl:equivalentClass schema:CreativeWork .

:Critique a owl:Class ;
    rdfs:label "Critique" ;
    rdfs:comment "A textual gradient / critique. BFO:GenericallyDependentContinuant." ;
    rdfs:subClassOf bfo:0000031 .

:DataClassification a owl:Class ;
    rdfs:label "Data Classification" ;
    rdfs:comment "A classification marking (e.g. Public, Confidential, Restricted) for data entities." ;
    rdfs:subClassOf bfo:0000031 .

:Dataset a owl:Class ;
    rdfs:label "Dataset" ;
    rdfs:comment "A data collection for ingestion or analysis. Aligned to schema:Dataset." ;
    rdfs:subClassOf bfo:0000031 ;
    owl:equivalentClass schema:Dataset .

:EmbeddingModel a owl:Class ;
    rdfs:label "Embedding Model" ;
    rdfs:comment "An AI model used specifically to generate high-dimensional vector embeddings." ;
    rdfs:subClassOf :System .

:Episode a owl:Class ;
    rdfs:label "Episode" ;
    rdfs:comment "A discrete interaction unit. BFO:Process, aligned to prov:Activity." ;
    rdfs:seeAlso prov:Activity ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty :occurredDuring ],
        bfo:0000015 .

:EvalCase a owl:Class ;
    rdfs:label "Eval Case" ;
    rdfs:comment "A regression evaluation case, often sourced from a human correction." .

:ExternalGraphReference a owl:Class ;
    rdfs:label "External Graph Reference" ;
    rdfs:comment "A reference to an external SPARQL or LPG knowledge graph endpoint. CONCEPT:KG-2.9" ;
    rdfs:subClassOf bfo:0000031 .

:Fact a owl:Class ;
    rdfs:label "Fact" ;
    rdfs:comment "An atomic factual assertion. BFO:GenericallyDependentContinuant." ;
    rdfs:seeAlso skos:Concept ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :derivedFrom ;
            owl:someValuesFrom :Evidence ],
        bfo:0000031 .

:File a owl:Class ;
    rdfs:label "Source File" ;
    rdfs:comment "A source code file." ;
    rdfs:seeAlso schema:DigitalDocument ;
    rdfs:subClassOf bfo:0000004 .

:Framework a owl:Class ;
    rdfs:label "Framework" ;
    rdfs:comment "A named mental model / repeatable method distilled from a source." .

:Goal a owl:Class ;
    rdfs:label "Goal" ;
    rdfs:comment "An objective the agent is pursuing. BFO:GenericallyDependentContinuant." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom bfo:0000001 ;
            owl:onProperty :influenced ],
        bfo:0000031 .

:GovernedEntity a owl:Class ;
    rdfs:label "Governed Entity" ;
    rdfs:comment "Any entity subject to at least one governance instrument. Membership is inferred." ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:onProperty :governedBy ;
            owl:someValuesFrom bfo:0000001 ] .

:Hypothesis a owl:Class ;
    rdfs:label "Hypothesis" ;
    rdfs:comment "A falsifiable predictive belief." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :influencedBy ;
            owl:someValuesFrom :Evidence ],
        :Belief .

:Insight a owl:Class ;
    rdfs:label "Insight" ;
    rdfs:comment "A distilled, reusable takeaway from a call or document." .

:LanguageModel a owl:Class ;
    rdfs:label "Language Model" ;
    rdfs:comment "An AI language model (e.g. Qwen, GPT-4) used by the agent ecosystem." ;
    rdfs:subClassOf :System .

:LegalEntity a owl:Class ;
    rdfs:label "Legal Entity" ;
    rdfs:comment "A legal concept, contract, or precedent." ;
    rdfs:subClassOf :DomainEntity .

:MedicalEntity a owl:Class ;
    rdfs:label "Medical Entity" ;
    rdfs:comment "A medical concept, condition, or entity. BFO:IndependentContinuant stub for medical domain extension." ;
    rdfs:seeAlso schema:MedicalEntity ;
    rdfs:subClassOf bfo:0000004 .

:Memory a owl:Class ;
    rdfs:label "Memory" ;
    rdfs:comment "A stored memory or knowledge fragment. BFO:GenericallyDependentContinuant, aligned to prov:Entity." ;
    rdfs:seeAlso prov:Entity ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :ownedBy ;
            owl:someValuesFrom bfo:0000004 ],
        bfo:0000031 .

:Module a owl:Class ;
    rdfs:label "Module" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :partOf ;
            owl:someValuesFrom bfo:0000001 ],
        bfo:0000004 .

:Observation a owl:Class ;
    rdfs:label "Observation" ;
    rdfs:comment "Something perceived by the agent. Subtype of Event, aligned to prov:Activity." ;
    rdfs:seeAlso prov:Activity ;
    rdfs:subClassOf :Event .

:OutcomeEvaluation a owl:Class ;
    rdfs:label "Outcome Evaluation" ;
    rdfs:comment "A reward/evaluation record. BFO:GenericallyDependentContinuant." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :derivedFrom ;
            owl:someValuesFrom :Decision ],
        bfo:0000031 .

:OwnedEntity a owl:Class ;
    rdfs:label "Owned Entity" ;
    rdfs:comment "Any entity that is owned by some agent. Membership is inferred." ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:onProperty :ownedBy ;
            owl:someValuesFrom bfo:0000004 ] .

:PeerReview a owl:Class ;
    rdfs:label "Peer Review" ;
    rdfs:comment "The inquiry's self-critique: confidence, bias check, frontier question (CONCEPT:KG-2.129)." ;
    rdfs:subClassOf :Concept .

:Perspective a owl:Class ;
    rdfs:label "Perspective" ;
    rdfs:comment "One expert lens whose questions surface a distinct source set (CONCEPT:KG-2.127)." ;
    rdfs:subClassOf :Concept .

:Playbook a owl:Class ;
    rdfs:label "Playbook" ;
    rdfs:comment "An executable, reusable procedure distilled from calls/docs. Crosswalked to the canonical BusinessProcess family." .

:Policy a owl:Class ;
    rdfs:label "Policy" ;
    rdfs:comment "A governance rule or constraint." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom bfo:0000001 ;
            owl:onProperty :governedBy ],
        bfo:0000031 .

:Preference a owl:Class ;
    rdfs:label "Preference" ;
    rdfs:comment "A learned/asserted preference influencing routing or retrieval." .

:Principle a owl:Class ;
    rdfs:label "Principle" ;
    rdfs:comment "A distilled, reusable operational rule." ;
    rdfs:subClassOf bfo:0000031 .

:Procedure a owl:Class ;
    rdfs:label "Procedure" ;
    rdfs:comment "An operational procedure or SOP. BFO:Process, aligned to schema:HowTo." ;
    rdfs:seeAlso schema:HowTo ;
    rdfs:subClassOf bfo:0000015 .

:ReasoningTrace a owl:Class ;
    rdfs:label "Reasoning Trace" ;
    rdfs:comment "A chain-of-thought step. BFO:Process, aligned to prov:Activity." ;
    rdfs:seeAlso prov:Activity ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hadParticipant ;
            owl:someValuesFrom :Agent ],
        bfo:0000015 .

:Reflection a owl:Class ;
    rdfs:label "Reflection" ;
    rdfs:comment "A high-level reflective summary." ;
    rdfs:subClassOf bfo:0000020 .

:Regulation a owl:Class ;
    rdfs:label "Regulation" ;
    rdfs:comment "A compliance or regulatory rule. BFO:GenericallyDependentContinuant." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :approvedBy ;
            owl:someValuesFrom bfo:0000004 ],
        bfo:0000031 .

:ResearchInquiry a owl:Class ;
    rdfs:label "Research Inquiry" ;
    rdfs:comment "A multi-perspective inquiry over a topic (CONCEPT:KG-2.127)." ;
    rdfs:subClassOf :Concept .

:Role a owl:Class ;
    rdfs:label "Role" ;
    rdfs:comment "A time-bounded role a Person plays. BFO:SpecificallyDependentContinuant (a realizable entity — a disposition of a person)." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty :approvedBy ],
        bfo:0000020 .

:RootEntity a owl:Class ;
    rdfs:label "Root Entity" ;
    rdfs:comment "An entity with no parent — the root of a lineage chain. Membership is inferred." ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:maxCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onProperty :hasParent ] .

:ScientificEntity a owl:Class ;
    rdfs:label "Scientific Entity" ;
    rdfs:comment "A scientific concept, phenomenon, or measurement." ;
    rdfs:subClassOf :DomainEntity .

:SecurityClearance a owl:Class ;
    rdfs:label "Security Clearance" ;
    rdfs:comment "An attribute defining the security clearance level of an Agent or Role." ;
    rdfs:subClassOf bfo:0000031 .

:SoftwareProject a owl:Class ;
    rdfs:label "Software Project" ;
    rdfs:comment "A software project or repository. BFO:IndependentContinuant." ;
    rdfs:seeAlso schema:SoftwareSourceCode ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :createdBy ;
            owl:someValuesFrom bfo:0000004 ],
        [ a owl:Restriction ;
            owl:allValuesFrom bfo:0000001 ;
            owl:onProperty :dependsOn ],
        bfo:0000004 .

:SourceRule a owl:Class ;
    rdfs:label "Source Rule" ;
    rdfs:comment "A rule governing which sources may be used (e.g. never in public content)." ;
    rdfs:subClassOf :GovernanceRule .

:Symbol a owl:Class ;
    rdfs:label "Code Symbol" ;
    rdfs:subClassOf bfo:0000004 .

:Team a owl:Class ;
    rdfs:label "Team" ;
    rdfs:comment "A team of agents or people. BFO:IndependentContinuant." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty :hasMember ],
        [ a owl:Restriction ;
            owl:allValuesFrom bfo:0000004 ;
            owl:onProperty :hasMember ],
        bfo:0000004 .

:Tool a owl:Class ;
    rdfs:label "Tool" ;
    rdfs:comment "A software tool or instrument. BFO:IndependentContinuant, aligned to schema:SoftwareApplication." ;
    rdfs:seeAlso schema:SoftwareApplication ;
    rdfs:subClassOf bfo:0000004 .

:ValidityInterval a owl:Class ;
    rdfs:label "Validity Interval" ;
    rdfs:comment "The event-time window during which a fact is TRUE in the world. Aligned to OWL-Time time:Interval." ;
    rdfs:subClassOf time:Interval .

:VoiceRule a owl:Class ;
    rdfs:label "Voice Rule" ;
    rdfs:comment "A rule governing tone/phrasing/brand voice." ;
    rdfs:subClassOf :GovernanceRule .

:alignedWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "aligned with" ;
    rdfs:comment """Declares that two entities from different domains or
sources represent the same real-world thing. Weaker than owl:sameAs.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 .

:authorOf a owl:ObjectProperty ;
    rdfs:label "author of" ;
    rdfs:comment "Links a creator to their creation. Inverse of createdBy." ;
    rdfs:domain bfo:0000004 ;
    rdfs:range bfo:0000001 ;
    owl:inverseOf :createdBy .

:classifiedAs a owl:ObjectProperty ;
    rdfs:label "classified as" ;
    rdfs:comment """Links an entity to its classification category.
Works for DataClassification, SecurityClearance, risk tier, etc.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000031 .

:contains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    rdfs:comment "A Place or container holding other entities. Inverse of locatedIn." ;
    rdfs:domain :Place ;
    rdfs:range bfo:0000004 ;
    owl:inverseOf :locatedIn .

:corrects a owl:ObjectProperty ;
    rdfs:label "corrects" ;
    rdfs:comment "Links a Correction to the node/output it corrects." ;
    rdfs:domain :Correction .

:dependencyOf a owl:ObjectProperty ;
    rdfs:label "dependency of" ;
    rdfs:comment "Reverse dependency — this entity is depended upon. Inverse of dependsOn." ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 ;
    owl:inverseOf :dependsOn .

:hadDerivation a owl:ObjectProperty ;
    rdfs:label "had derivation" ;
    rdfs:comment "Links a source to an entity derived from it. Inverse of derivedFrom." ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 ;
    owl:inverseOf :derivedFrom .

:hasChild a owl:ObjectProperty ;
    rdfs:label "has child" ;
    rdfs:comment "Direct child/derivative. Inverse of hasParent." ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 ;
    owl:inverseOf :hasParent .

:hasDescendant a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has descendant" ;
    rdfs:comment "Any descendant in the lineage chain. Inverse of hasAncestor." ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 ;
    owl:inverseOf :hasAncestor .

:hasPart a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has part" ;
    rdfs:comment "Inverse of partOf. Links a whole to its parts." ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 ;
    owl:inverseOf :partOf .

:hasSibling a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "has sibling" ;
    rdfs:comment "Shares a common parent (biological, organizational, or conceptual)." ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 .

:inspiredChange a owl:ObjectProperty ;
    rdfs:label "inspired change" ;
    rdfs:comment "Links a research Document to a code change it inspired." ;
    rdfs:domain :Document ;
    rdfs:range :Concept .

:occurredAt a owl:ObjectProperty ;
    rdfs:label "occurred at" ;
    rdfs:comment "Links an Event to the Place where it happened." ;
    rdfs:domain :Event ;
    rdfs:range :Place .

:precedes a owl:ObjectProperty ;
    rdfs:label "precedes" ;
    rdfs:comment "Temporal ordering — this entity comes before another. Inverse of succeeds." ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 ;
    owl:inverseOf :succeeds .

:supersedes a owl:ObjectProperty ;
    rdfs:label "supersedes" ;
    rdfs:comment "Links a TemporalFact to the prior fact it superseded on contradiction (KG-2.251)." ;
    rdfs:domain :TemporalFact ;
    rdfs:range :TemporalFact ;
    rdfs:subPropertyOf prov:wasRevisionOf .

:triggeredIncident a owl:ObjectProperty ;
    rdfs:label "triggered incident" ;
    rdfs:comment "Links an infrastructure event (ContainerStack crash) to the Incident it raised." ;
    rdfs:domain :System ;
    rdfs:range :Incident .

:txFrom a owl:DatatypeProperty ;
    rdfs:label "transaction from" ;
    rdfs:comment "Transaction-time start (epoch seconds) — when the engine began believing the fact." ;
    rdfs:domain :TemporalFact ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf prov:generatedAtTime .

:txTo a owl:DatatypeProperty ;
    rdfs:label "transaction to" ;
    rdfs:comment "Transaction-time end (epoch seconds) — when the belief was retracted/superseded; absent = currently believed." ;
    rdfs:domain :TemporalFact ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf prov:invalidatedAtTime .

:validFrom a owl:DatatypeProperty ;
    rdfs:label "valid from" ;
    rdfs:comment "Event-time start (epoch seconds) — when the fact became true." ;
    rdfs:domain :TemporalFact ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf time:hasBeginning .

:validUntil a owl:DatatypeProperty ;
    rdfs:label "valid until" ;
    rdfs:comment "Event-time end (epoch seconds) — when the fact stopped being true; absent = still current." ;
    rdfs:domain :TemporalFact ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf time:hasEnd .

:Belief a owl:Class ;
    rdfs:label "Belief" ;
    rdfs:comment "A claim-with-confidence held by an agent. BFO:SpecificallyDependentContinuant." ;
    rdfs:subClassOf bfo:0000020 .

:Code a owl:Class ;
    rdfs:label "Code" ;
    rdfs:seeAlso schema:SoftwareSourceCode ;
    rdfs:subClassOf bfo:0000004 .

:Correction a owl:Class ;
    rdfs:label "Correction" ;
    rdfs:comment "A human-asserted correction of an agent output, fact, or routing decision." .

:Decision a owl:Class ;
    rdfs:label "Decision" ;
    rdfs:comment "A decision linking Goal → Action → Outcome. Subtype of Event." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :hadParticipant ;
            owl:someValuesFrom :Agent ],
        :Event .

:Organization a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:comment "An organizational entity. BFO:IndependentContinuant. Aligned to foaf:Organization, schema:Organization, and fibo-org:Organization." ;
    rdfs:seeAlso schema:Organization,
        fibo-org:Organization ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty :hasMember ],
        bfo:0000004 ;
    owl:equivalentClass foaf:Organization .

:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:comment "A human individual. BFO:IndependentContinuant, aligned to foaf:Person and schema:Person." ;
    rdfs:seeAlso schema:Person ;
    rdfs:subClassOf bfo:0000004 ;
    owl:disjointWith :Code,
        :Document ;
    owl:equivalentClass foaf:Person .

:Phase a owl:Class ;
    rdfs:label "Temporal Phase" ;
    rdfs:comment "A named temporal interval. BFO:TemporalRegion, aligned to time:ProperInterval." ;
    rdfs:seeAlso time:ProperInterval ;
    rdfs:subClassOf bfo:0000008 .

:Server a owl:Class ;
    rdfs:label "Server" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :locatedIn ;
            owl:someValuesFrom :Place ],
        bfo:0000004 .

:Skill a owl:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "A reusable agent skill or capability." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :Skill ;
            owl:onProperty :dependsOn ],
        bfo:0000004 .

:blocksTask a owl:ObjectProperty ;
    rdfs:label "blocks task" ;
    rdfs:comment "Links an Incident to the Task(s) it blocks." ;
    rdfs:domain :Incident ;
    rdfs:range :Task .

:influenced a owl:ObjectProperty ;
    rdfs:label "influenced" ;
    rdfs:comment "Active influence. Inverse of influencedBy." ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 ;
    owl:inverseOf :influencedBy .

:memberOf a owl:ObjectProperty ;
    rdfs:label "member of" ;
    rdfs:comment """Links an entity to a group, organization, or collection it belongs to.
Works for Person→Organization, Agent→Team, Server→Cluster, etc.  Membership is
a specialization of mereological part-hood.""" ;
    rdfs:domain bfo:0000004 ;
    rdfs:range bfo:0000004 ;
    rdfs:subPropertyOf :partOf .

:occurredDuring a owl:ObjectProperty ;
    rdfs:label "occurred during" ;
    rdfs:comment "Links an Event to the temporal Phase during which it took place." ;
    rdfs:domain :Event ;
    rdfs:range :Phase .

:owns a owl:ObjectProperty ;
    rdfs:label "owns" ;
    rdfs:comment """Links an entity to something it owns or is responsible for.
Works for Person→Asset, Organization→System, Team→SoftwareProject, etc.""" ;
    rdfs:domain bfo:0000004 ;
    rdfs:range bfo:0000001 .

:participatedIn a owl:ObjectProperty ;
    rdfs:label "participated in" ;
    rdfs:comment """Links any entity to an Event it participated in.
Aligned to prov:wasAssociatedWith (inverse direction).""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range :Event .

:selfHealedVia a owl:ObjectProperty ;
    rdfs:label "self healed via" ;
    rdfs:comment "Links an Incident to the remediation Action that resolved it." ;
    rdfs:domain :Incident ;
    rdfs:range :Action ;
    owl:inverseOf :resolvedIncident .

:succeeds a owl:ObjectProperty ;
    rdfs:label "succeeds" ;
    rdfs:comment """Temporal ordering — this entity comes after another.
Works for versions, phases, events, role transitions, etc.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 .

:Agent a owl:Class ;
    rdfs:label "Agent Specialist" ;
    rdfs:comment "An autonomous software agent. BFO:IndependentContinuant, aligned to prov:SoftwareAgent." ;
    rdfs:subClassOf bfo:0000004 ;
    owl:equivalentClass prov:SoftwareAgent .

:Document a owl:Class ;
    rdfs:label "Document" ;
    rdfs:comment "A digital or physical document. BFO:GenericallyDependentContinuant. Aligned to schema:DigitalDocument and bibo:Document." ;
    rdfs:seeAlso bibo:Document,
        schema:DigitalDocument ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :createdBy ;
            owl:someValuesFrom bfo:0000004 ],
        bfo:0000031 .

:DomainEntity a owl:Class ;
    rdfs:label "Domain Entity" ;
    rdfs:comment "Base class for cross-domain associative reasoning." ;
    rdfs:subClassOf bfo:0000004 .

:Evidence a owl:Class ;
    rdfs:label "Evidence" ;
    rdfs:comment "A claim or finding grounded in source material." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :derivedFrom ;
            owl:someValuesFrom bfo:0000001 ],
        bfo:0000031 .

:GovernanceRule a owl:Class ;
    rdfs:label "Governance Rule" ;
    rdfs:comment "A durable rule (forbid/prefer/demote) consulted at retrieval time." .

:approvedBy a owl:ObjectProperty ;
    rdfs:label "approved by" ;
    rdfs:comment """Links an entity to the Person, Role, or Organization that
approved/authorized it.  Decision audit trail.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000004 .

:governedBy a owl:ObjectProperty ;
    rdfs:label "governed by" ;
    rdfs:comment """Links an entity to the Policy, Regulation, or governance body
that controls it.  Works for System→Policy, Organization→Regulation, etc.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 .

:hadParticipant a owl:ObjectProperty ;
    rdfs:label "had participant" ;
    rdfs:comment "Links an Event to an entity that participated. Inverse of participatedIn." ;
    rdfs:domain :Event ;
    rdfs:range bfo:0000001 ;
    owl:inverseOf :participatedIn .

:hasAncestor a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has ancestor" ;
    rdfs:comment """Any ancestor in the lineage chain.  Transitivity enables
the OWL reasoner to infer full ancestry from asserted hasParent edges.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 .

:hasParent a owl:ObjectProperty ;
    rdfs:label "has parent" ;
    rdfs:comment """Direct parent/progenitor relationship (literal or figurative).
Works for biological parents, software forks, organizational spin-offs,
mentor relationships, concept derivation chains, or event hierarchies.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 ;
    rdfs:subPropertyOf :hasAncestor .

:influencedBy a owl:ObjectProperty ;
    rdfs:label "influenced by" ;
    rdfs:comment """Generic influence relationship. Aligned to prov:wasInfluencedBy.
Works for Person→Person (mentor), Document→Concept, Event→Decision, etc.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 .

:locatedIn a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "located in" ;
    rdfs:comment """Spatial or logical containment.  Transitivity enables
Server→Rack→DataCenter→Region inference.  Works for physical and virtual.""" ;
    rdfs:domain bfo:0000004 ;
    rdfs:range :Place .

:ownedBy a owl:ObjectProperty ;
    rdfs:label "owned by" ;
    rdfs:comment "Links an entity to its owner. Inverse of owns." ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000004 ;
    owl:inverseOf :owns .

:resolvedIncident a owl:ObjectProperty ;
    rdfs:label "resolved incident" ;
    rdfs:comment "Links a remediation Action to the Incident it resolved." ;
    rdfs:domain :Action ;
    rdfs:range :Incident .

bfo:0000003 a owl:Class ;
    rdfs:label "Occurrent" ;
    rdfs:comment "BFO:Occurrent — entities that unfold or happen over time." ;
    rdfs:subClassOf bfo:0000001 .

bfo:0000008 a owl:Class ;
    rdfs:label "Temporal Region" ;
    rdfs:comment "BFO:TemporalRegion — a region of time." ;
    rdfs:subClassOf bfo:0000003 .

:Action a owl:Class ;
    rdfs:label "Action" ;
    rdfs:comment "An agent action. BFO:Process, aligned to prov:Activity." ;
    rdfs:seeAlso prov:Activity ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :Incident ;
            owl:onProperty :resolvedIncident ],
        bfo:0000015 .

:System a owl:Class ;
    rdfs:label "System" ;
    rdfs:comment "A software system or service." ;
    rdfs:subClassOf bfo:0000004 .

:hasMember a owl:ObjectProperty ;
    rdfs:label "has member" ;
    rdfs:comment "Links a group/collection to its members. Inverse of memberOf." ;
    rdfs:domain bfo:0000004 ;
    rdfs:range bfo:0000004 ;
    owl:inverseOf :memberOf .

:partOf a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "part of" ;
    rdfs:comment """Mereological part-whole relationship. Transitivity enables
Module→System→Platform inference. BFO-standard mereology.  A part necessarily
depends on its whole, so partOf is a sub-property of dependsOn.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 ;
    rdfs:subPropertyOf :dependsOn .

bfo:0000002 a owl:Class ;
    rdfs:label "Continuant" ;
    rdfs:comment "BFO:Continuant — entities that persist through time." ;
    rdfs:subClassOf bfo:0000001 .

bfo:0000020 a owl:Class ;
    rdfs:label "Specifically Dependent Continuant" ;
    rdfs:comment "BFO:SpecificallyDependentContinuant — depends on a specific bearer." ;
    rdfs:subClassOf bfo:0000002 .

:Place a owl:Class ;
    rdfs:label "Place" ;
    rdfs:comment "A physical, virtual, or contextual location. BFO:IndependentContinuant." ;
    rdfs:seeAlso schema:Place ;
    rdfs:subClassOf bfo:0000004 .

:createdBy a owl:ObjectProperty ;
    rdfs:label "created by" ;
    rdfs:comment """Attribution of creation. Works for Document→Person,
SoftwareProject→Team, CreativeWork→Agent, etc. Aligned to prov:wasAttributedTo.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000004 .

:dependsOn a owl:ObjectProperty ;
    rdfs:label "depends on" ;
    rdfs:comment """Generic dependency relationship.  Works for System→System,
SoftwareProject→SoftwareProject, Task→Task, Skill→Skill, etc.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 .

:derivedFrom a owl:ObjectProperty ;
    rdfs:label "derived from" ;
    rdfs:comment """Links an entity to a source it was derived from.
Aligned to prov:wasDerivedFrom.  Works for fork→upstream,
translation→original, dataset→raw_source, etc.""" ;
    rdfs:domain bfo:0000001 ;
    rdfs:range bfo:0000001 .

:Incident a owl:Class ;
    rdfs:label "Incident" ;
    rdfs:comment "A production incident. Subtype of Event." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onProperty :blocksTask ],
        [ a owl:Restriction ;
            owl:allValuesFrom :Action ;
            owl:onProperty :selfHealedVia ],
        :Event .

:TemporalFact a owl:Class ;
    rdfs:label "Temporal Fact" ;
    rdfs:comment "An asserted fact carrying a validity interval (event time) and a belief interval (transaction time). Reifies a bi-temporal engine edge (CONCEPT:KG-2.252)." ;
    rdfs:subClassOf bfo:0000031 .

bfo:0000015 a owl:Class ;
    rdfs:label "Process" ;
    rdfs:comment "BFO:Process — an occurrent that has temporal parts." ;
    rdfs:subClassOf bfo:0000003 .

:Concept a owl:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "An atomic knowledge unit. BFO:GenericallyDependentContinuant, aligned to skos:Concept for full SKOS taxonomy support." ;
    rdfs:subClassOf bfo:0000031,
        skos:Concept .

:Event a owl:Class ;
    rdfs:label "Event" ;
    rdfs:comment "A temporally-bounded happening. BFO:Process, aligned to schema:Event and prov:Activity." ;
    rdfs:seeAlso prov:Activity ;
    rdfs:subClassOf bfo:0000015 ;
    owl:equivalentClass schema:Event .

bfo:0000031 a owl:Class ;
    rdfs:label "Generically Dependent Continuant" ;
    rdfs:comment "BFO:GenericallyDependentContinuant — information entities." ;
    rdfs:subClassOf bfo:0000002 .

bfo:0000004 a owl:Class ;
    rdfs:label "Independent Continuant" ;
    rdfs:comment "BFO:IndependentContinuant — can exist autonomously." ;
    rdfs:subClassOf bfo:0000002 .

bfo:0000001 a owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "BFO:Entity — root of all entities." .

[] a owl:AllDisjointClasses ;
    owl:members ( bfo:0000004 bfo:0000031 bfo:0000015 bfo:0000008 ) .

[] a owl:AllDisjointClasses ;
    owl:members ( :Person :Organization :Server :Incident :Event ) .

