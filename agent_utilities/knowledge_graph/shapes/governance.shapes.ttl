@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:ADRShape a sh:NodeShape ;
    sh:description "ADRs must capture context, decision, and authority." ;
    sh:name "Architecture Decision Record Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "ADR must have a context describing why the decision was needed." ;
            sh:minCount 1 ;
            sh:path :context ],
        [ sh:datatype xsd:string ;
            sh:message "ADR must have a decision describing what was decided." ;
            sh:minCount 1 ;
            sh:path :decision ],
        [ sh:datatype xsd:string ;
            sh:message "ADR must have an authority identifying who approved it." ;
            sh:minCount 1 ;
            sh:path :authority ] ;
    sh:targetClass :ArchitectureDecisionRecord .

:AgentShape a sh:NodeShape ;
    sh:description "Agents must have a name." ;
    sh:name "Agent Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "Agent must have a name." ;
            sh:minCount 1 ;
            sh:path :name ] ;
    sh:targetClass :Agent .

:PolicyShape a sh:NodeShape ;
    sh:description "Policies should be linked to the concepts they govern." ;
    sh:name "Policy Shape" ;
    sh:property [ sh:message "Policy should be linked to at least one Concept via motivatedBy." ;
            sh:minCount 0 ;
            sh:path :motivatedBy ;
            sh:severity sh:Warning ] ;
    sh:targetClass :Policy .

:RequirementShape a sh:NodeShape ;
    sh:description "Requirements should have a priority level." ;
    sh:name "Requirement Shape" ;
    sh:property [ sh:message "Requirement should have a priority (critical/high/medium/low)." ;
            sh:minCount 0 ;
            sh:path :priority ;
            sh:severity sh:Warning ] ;
    sh:targetClass :Requirement .

:SoftwareFeatureShape a sh:NodeShape ;
    sh:description "Software features should be traceable to specifications." ;
    sh:name "Software Feature Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "SoftwareFeature must have a name." ;
            sh:minCount 1 ;
            sh:path :name ] ;
    sh:targetClass :SoftwareFeature .

:SpecificationShape a sh:NodeShape ;
    sh:description "Specifications must have a name and description." ;
    sh:name "Specification Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "Specification must have a name." ;
            sh:minCount 1 ;
            sh:path :name ] ;
    sh:targetClass :Specification .

:TestCaseShape a sh:NodeShape ;
    sh:description "Test cases should track their execution status." ;
    sh:name "Test Case Shape" ;
    sh:property [ sh:message "TestCase should have a testStatus (passed/failed/skipped/pending)." ;
            sh:minCount 0 ;
            sh:path :testStatus ;
            sh:severity sh:Info ] ;
    sh:targetClass :TestCase .

