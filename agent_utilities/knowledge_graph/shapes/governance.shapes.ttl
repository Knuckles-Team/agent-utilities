@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:ADRShape a sh:NodeShape ;
    sh:description "ADRs must capture context, decision, and authority." ;
    sh:name "Architecture Decision Record Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "ADR must have a context describing why the decision was needed." ;
            sh:minCount 1 ;
            sh:path :context ],
        [ sh:datatype xsd:string ;
            sh:message "ADR must have a decision describing what was decided." ;
            sh:minCount 1 ;
            sh:path :decision ],
        [ sh:datatype xsd:string ;
            sh:message "ADR must have an authority identifying who approved it." ;
            sh:minCount 1 ;
            sh:path :authority ] ;
    sh:targetClass :ArchitectureDecisionRecord .

:AgentShape a sh:NodeShape ;
    sh:description "Agents must have a name." ;
    sh:name "Agent Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "Agent must have a name." ;
            sh:minCount 1 ;
            sh:path :name ] ;
    sh:targetClass :Agent .

:CapabilityShape a sh:NodeShape ;
    sh:description "ServiceCapability instances must be named and carry their abstract capability category." ;
    sh:name "Service Capability Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "Capability must have a name." ;
            sh:minCount 1 ;
            sh:path :name ],
        [ sh:datatype xsd:string ;
            sh:message "Capability must declare its capabilityCategory." ;
            sh:minCount 1 ;
            sh:path :capabilityCategory ] ;
    sh:targetClass :ServiceCapability .

:HookShape a sh:NodeShape ;
    sh:description "Hooks must specify their trigger lifecycle event." ;
    sh:name "Hook Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "Hook must specify its trigger lifecycle event via triggersOnEvent." ;
            sh:minCount 1 ;
            sh:path :triggersOnEvent ] ;
    sh:targetClass :Hook .

:OntologyActionShape a sh:NodeShape ;
    sh:description "CONCEPT:KG-2.25 — Governed ontology actions must be named, permission-gated, and typed over the objects they act on." ;
    sh:name "Ontology Action Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "OntologyAction must have a name." ;
            sh:minCount 1 ;
            sh:path :name ],
        [ sh:datatype xsd:string ;
            sh:message "OntologyAction must declare its required_capability (the gating ServiceCapability)." ;
            sh:minCount 1 ;
            sh:path :required_capability ],
        [ sh:datatype xsd:string ;
            sh:message "OntologyAction must declare at least one acts_on ontology object type." ;
            sh:minCount 1 ;
            sh:path :acts_on ] ;
    sh:targetClass :OntologyAction .

:OptimizationPatternShape a sh:NodeShape ;
    sh:description "Optimization patterns must specify their directory scope." ;
    sh:name "Optimization Pattern Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "Optimization pattern must define its directory scope via scopesPath." ;
            sh:minCount 1 ;
            sh:path :scopesPath ] ;
    sh:targetClass :OptimizationPattern .

:PolicyShape a sh:NodeShape ;
    sh:description "Policies should be linked to the concepts they govern." ;
    sh:name "Policy Shape" ;
    sh:property [ sh:message "Policy should be linked to at least one Concept via motivatedBy." ;
            sh:minCount 0 ;
            sh:path :motivatedBy ;
            sh:severity sh:Warning ] ;
    sh:targetClass :Policy .

:RequirementShape a sh:NodeShape ;
    sh:description "Requirements should have a priority level." ;
    sh:name "Requirement Shape" ;
    sh:property [ sh:message "Requirement should have a priority (critical/high/medium/low)." ;
            sh:minCount 0 ;
            sh:path :priority ;
            sh:severity sh:Warning ] ;
    sh:targetClass :Requirement .

:SoftwareFeatureShape a sh:NodeShape ;
    sh:description "Software features should be traceable to specifications." ;
    sh:name "Software Feature Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "SoftwareFeature must have a name." ;
            sh:minCount 1 ;
            sh:path :name ] ;
    sh:targetClass :SoftwareFeature .

:SpecificationShape a sh:NodeShape ;
    sh:description "Specifications must have a name and description." ;
    sh:name "Specification Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "Specification must have a name." ;
            sh:minCount 1 ;
            sh:path :name ] ;
    sh:targetClass :Specification .

:TestCaseShape a sh:NodeShape ;
    sh:description "Test cases should track their execution status." ;
    sh:name "Test Case Shape" ;
    sh:property [ sh:message "TestCase should have a testStatus (passed/failed/skipped/pending)." ;
            sh:minCount 0 ;
            sh:path :testStatus ;
            sh:severity sh:Info ] ;
    sh:targetClass :TestCase .

:ToolShape a sh:NodeShape ;
    sh:description "Tools are concrete platform/service instances and must be named and classified by the capability they provide." ;
    sh:name "Tool Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Tool must have exactly one name." ;
            sh:minCount 1 ;
            sh:path :name ],
        [ sh:datatype xsd:string ;
            sh:message "Tool must declare at least one capabilityCategory it provides." ;
            sh:minCount 1 ;
            sh:path :capabilityCategory ] ;
    sh:targetClass :Tool .


:ObjectEditShape a sh:NodeShape ;
    sh:description "Durable object edits must carry a valid edit_type and the id of the object they mutate (CONCEPT:KG-2.43)." ;
    sh:name "Object Edit Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:in ( "property_set" "link_add" "link_remove" "object_create" "object_delete" ) ;
            sh:maxCount 1 ;
            sh:message "ObjectEdit.edit_type must be one of the five EditType values." ;
            sh:minCount 1 ;
            sh:path :edit_type ],
        [ sh:datatype xsd:string ;
            sh:message "ObjectEdit must name the object_id it edits." ;
            sh:minCount 1 ;
            sh:path :object_id ] ;
    sh:targetClass :ObjectEdit .

:ChunkShape a sh:NodeShape ;
    sh:description "A document Chunk must reference its parent document and carry an ordinal position (CONCEPT:KG-2.48)." ;
    sh:name "Document Chunk Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "Chunk must reference its parent document_id." ;
            sh:minCount 1 ;
            sh:path :document_id ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:message "Chunk must carry exactly one ordinal position." ;
            sh:path :position ] ;
    sh:targetClass :Chunk .

:WorkflowDefinitionShape a sh:NodeShape ;
    sh:description "CONCEPT:ORCH-1.42 — an executable workflow definition must be named and carry at least one step before it may be dispatched (constraints mirror what WorkflowStore persists: name + step_count)." ;
    sh:name "Workflow Definition Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "WorkflowDefinition must have a name." ;
            sh:minCount 1 ;
            sh:path :name ],
        [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:message "WorkflowDefinition must have at least one step (step_count >= 1)." ;
            sh:minCount 1 ;
            sh:minInclusive 1 ;
            sh:path :step_count ] ;
    sh:targetClass :WorkflowDefinition .

:WorkflowStepShape a sh:NodeShape ;
    sh:description "CONCEPT:ORCH-1.42 — every workflow step must name a resolvable execution target (the WorkflowStep node_id WorkflowStore persists is the agent/tool the step dispatches to)." ;
    sh:name "Workflow Step Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "WorkflowStep must carry node_id (the agent/tool execution target)." ;
            sh:minCount 1 ;
            sh:path :node_id ] ;
    sh:targetClass :WorkflowStep .

:ScheduleShape a sh:NodeShape ;
    sh:description "A unified-scheduler Schedule must declare its trigger kind (CONCEPT:OS-5.44)." ;
    sh:name "Schedule Shape" ;
    sh:property [ sh:datatype xsd:string ;
            sh:in ( "cron" "interval" "adaptive" ) ;
            sh:message "Schedule must declare trigger in {cron, interval, adaptive}." ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:path :trigger ] ;
    sh:targetClass :Schedule .

:DeadLetterTaskShape a sh:NodeShape ;
    sh:description "A dead-letter Task records the attempts it exhausted (CONCEPT:KG-2.113)." ;
    sh:name "Dead-Letter Task Shape" ;
    sh:property [ sh:datatype xsd:integer ;
            sh:message "DeadLetterTask must record the attempt count it exhausted." ;
            sh:minCount 1 ;
            sh:path :attempts ] ;
    sh:targetClass :DeadLetterTask .
