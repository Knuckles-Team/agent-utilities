:WorldViewDomain a owl:Class ;
    rdfs:label "WorldView Domain" ;
    rdfs:comment "One of the fixed top-level subject domains of the WorldView scheme. Every :Topic — including runtime-minted, context-derived sub-topics — is transitively skos:broader-linked up to exactly one WorldViewDomain." ;
    rdfs:subClassOf :Topic .

:WorldViewScheme a skos:ConceptScheme ;
    rdfs:label "WorldView Subject-Domain Scheme" ;
    skos:prefLabel "WorldView" .

