@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:ContentDraft a owl:Class ;
    rdfs:label "Content Draft" ;
    rdfs:comment "An unpublished draft of a SocialPost. Subclass of SocialPost." ;
    rdfs:subClassOf :SocialPost .

:aggregatesDaily a owl:ObjectProperty ;
    rdfs:label "aggregates daily" ;
    rdfs:comment """Links an AggregatedEngagement to its constituent DailyEngagement
nodes. Enables drill-down from totals to daily trends.""" ;
    rdfs:domain :AggregatedEngagement ;
    rdfs:range :DailyEngagement .

:broadcastEngagement a owl:ObjectProperty ;
    rdfs:label "broadcast engagement" ;
    rdfs:comment "Links an EngagementMetric to a BroadcastSession." ;
    rdfs:domain :EngagementMetric ;
    rdfs:range :BroadcastSession .

:broadcastedVia a owl:ObjectProperty ;
    rdfs:label "broadcasted via" ;
    rdfs:comment "Links a BroadcastSession to the streaming platform System." ;
    rdfs:domain :BroadcastSession ;
    rdfs:range :System .

:comments a owl:DatatypeProperty ;
    rdfs:label "comments" ;
    rdfs:domain :EngagementMetric ;
    rdfs:range xsd:integer .

:concurrentViewers a owl:DatatypeProperty ;
    rdfs:label "concurrent viewers" ;
    rdfs:domain :AudienceMetric ;
    rdfs:range xsd:integer .

:createdBy a owl:ObjectProperty ;
    rdfs:label "created by" ;
    rdfs:domain :SocialPost ;
    rdfs:range :Person .

:derivedFromContent a owl:ObjectProperty ;
    rdfs:label "derived from content" ;
    rdfs:comment "Links a BroadcastSession to the SocialPost that inspired it." ;
    rdfs:domain :BroadcastSession ;
    rdfs:range :SocialPost .

:engagementDate a owl:DatatypeProperty ;
    rdfs:label "engagement date" ;
    rdfs:domain :DailyEngagement ;
    rdfs:range xsd:date .

:engagementOf a owl:ObjectProperty ;
    rdfs:label "engagement of" ;
    rdfs:comment "Links an EngagementMetric to its source content." ;
    rdfs:domain :EngagementMetric ;
    rdfs:range :SocialPost .

:highlightFrom a owl:ObjectProperty ;
    rdfs:label "highlight from" ;
    rdfs:domain :StreamHighlight ;
    rdfs:range :BroadcastSession .

:impressions a owl:DatatypeProperty ;
    rdfs:label "impressions" ;
    rdfs:domain :EngagementMetric ;
    rdfs:range xsd:integer .

:likes a owl:DatatypeProperty ;
    rdfs:label "likes" ;
    rdfs:domain :EngagementMetric ;
    rdfs:range xsd:integer .

:peakViewers a owl:DatatypeProperty ;
    rdfs:label "peak viewers" ;
    rdfs:domain :AudienceMetric ;
    rdfs:range xsd:integer .

:platform a owl:DatatypeProperty ;
    rdfs:label "platform name" ;
    rdfs:comment "Platform identifier: postiz, owncast, x, linkedin, etc." ;
    rdfs:domain :SocialPost ;
    rdfs:range xsd:string .

:promotesResearch a owl:ObjectProperty ;
    rdfs:label "promotes research" ;
    rdfs:comment "Links a SocialPost to the research Document it promotes." ;
    rdfs:domain :SocialPost ;
    rdfs:range :Document .

:publishedOn a owl:ObjectProperty ;
    rdfs:label "published on" ;
    rdfs:comment "Links a SocialPost to the platform System it was published on." ;
    rdfs:domain :SocialPost ;
    rdfs:range :System .

:reach a owl:DatatypeProperty ;
    rdfs:label "reach" ;
    rdfs:domain :EngagementMetric ;
    rdfs:range xsd:integer .

:scheduledIn a owl:ObjectProperty ;
    rdfs:label "scheduled in" ;
    rdfs:comment "Links a SocialPost to its ContentCalendar slot." ;
    rdfs:domain :SocialPost ;
    rdfs:range :ContentCalendar .

:shares a owl:DatatypeProperty ;
    rdfs:label "shares" ;
    rdfs:domain :EngagementMetric ;
    rdfs:range xsd:integer .

<http://knuckles.team/kg/social> a owl:Ontology ;
    rdfs:label "Social & Content Ontology" ;
    rdfs:comment """Social media, content creation, and audience engagement ontology
bridging Postiz (content scheduling), Owncast (live streaming), and
social network analytics into the unified KG.

Supports both time-series engagement observations (one node per day for
trend analysis) AND aggregated snapshots (lifetime totals) with explicit
relationships between them.

Standards alignment: schema:SocialMediaPosting, schema:BroadcastEvent.""" ;
    owl:imports <http://knuckles.team/kg> .

:AggregatedEngagement a owl:Class ;
    rdfs:label "Aggregated Engagement" ;
    rdfs:comment """Lifetime or period-total engagement snapshot for a SocialPost
or BroadcastSession. Computed from DailyEngagement nodes.
Updated incrementally as new daily data arrives.""" ;
    rdfs:subClassOf :EngagementMetric .

:ContentCalendar a owl:Class ;
    rdfs:label "Content Calendar" ;
    rdfs:comment """A scheduled content publishing window. Organizes SocialPosts
into a coherent publication strategy. BFO:TemporalRegion via Phase.""" ;
    rdfs:subClassOf :Phase .

:StreamHighlight a owl:Class ;
    rdfs:label "Stream Highlight" ;
    rdfs:comment "A clipped highlight segment from a BroadcastSession." ;
    rdfs:subClassOf :CreativeWork .

:AudienceMetric a owl:Class ;
    rdfs:label "Audience Metric" ;
    rdfs:comment """Audience composition and reach data for a BroadcastSession.
Peak viewers, concurrent viewers, unique visitors.""" ;
    rdfs:subClassOf :Observation .

:DailyEngagement a owl:Class ;
    rdfs:label "Daily Engagement" ;
    rdfs:comment """A single day's engagement data point for a SocialPost or
BroadcastSession. Enables time-series trend analysis across days.
One node per day per content item.""" ;
    rdfs:subClassOf :EngagementMetric .

:BroadcastSession a owl:Class ;
    rdfs:label "Broadcast Session" ;
    rdfs:comment """A live stream session on Owncast or equivalent platform.
BFO:Process via Event. Aligned to schema:BroadcastEvent.""" ;
    rdfs:seeAlso schema:BroadcastEvent ;
    rdfs:subClassOf :Event .

:SocialPost a owl:Class ;
    rdfs:label "Social Post" ;
    rdfs:comment """A post published to one or more social platforms via Postiz.
BFO:GenericallyDependentContinuant. Aligned to schema:SocialMediaPosting.""" ;
    rdfs:seeAlso schema:SocialMediaPosting ;
    rdfs:subClassOf :CreativeWork .

:EngagementMetric a owl:Class ;
    rdfs:label "Engagement Metric" ;
    rdfs:comment """Base class for engagement data. Both time-series observations
and aggregated snapshots inherit from this class.
BFO:SpecificallyDependentContinuant via Observation.""" ;
    rdfs:subClassOf :Observation .

