@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:DataObject a owl:Class ;
    rdfs:label "Data Object" ;
    rdfs:comment """A data object managed within the EA inventory.
    ArchiMate: Application → DataObject.""" .

:dependsOn a owl:ObjectProperty ;
    rdfs:label "depends on" ;
    rdfs:comment "Links an Application to an ITComponent it depends on." ;
    rdfs:domain :Application ;
    rdfs:range :ITComponent .

:factsheetName a owl:DatatypeProperty ;
    rdfs:label "factsheet name" ;
    rdfs:comment "Human-readable display name of a LeanIX factsheet." ;
    rdfs:range xsd:string .

:supports a owl:ObjectProperty ;
    rdfs:label "supports" ;
    rdfs:comment "Links an Application to a BusinessCapability it supports." ;
    rdfs:domain :Application ;
    rdfs:range :BusinessCapability .

<http://knuckles.team/kg/leanix> a owl:Ontology ;
    rdfs:label "LeanIX Enterprise Architecture Ontology" ;
    rdfs:comment """LeanIX EA factsheet extensions (ArchiMate-style).
    Models Applications, IT Components, and Business Capabilities and the
    support/dependency relations between them.

    CONCEPT:KG-2.9 — self-registering enterprise source extractors.""" ;
    owl:imports <http://knuckles.team/kg> .

:BusinessCapability a owl:Class ;
    rdfs:label "Business Capability" ;
    rdfs:comment """A business capability supported by Applications.
    ArchiMate: Strategy → Capability.""" .

:ITComponent a owl:Class ;
    rdfs:label "IT Component" ;
    rdfs:comment """A technology building block (software/hardware) an
    Application depends on. ArchiMate: Technology → Node/SystemSoftware.""" .

:Application a owl:Class ;
    rdfs:label "Application" ;
    rdfs:comment """A business application from the LeanIX inventory.
    ArchiMate: Application → ApplicationComponent.""" .

