@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

:SkillProposal a owl:Class ;
    rdfs:label "Skill Proposal" ;
    rdfs:comment "CONCEPT:KG-2.90 — a propose-only atomic-skill candidate the background distiller synthesizes from a mapped process/task of any connected system; reviewed+approved by a human before it materializes." .

:SkillWorkflowProposal a owl:Class ;
    rdfs:label "Skill Workflow Proposal" ;
    rdfs:comment "CONCEPT:KG-2.90 — a propose-only skill-workflow candidate (composes atomic Skills) distilled from a flowsTo-chain of business tasks." ;
    rdfs:subClassOf :Workflow .

:automates a owl:ObjectProperty ;
    rdfs:label "automates" ;
    rdfs:comment """CONCEPT:KG-2.91 — a synthesized Skill / SkillWorkflow (or its
    proposal) AUTOMATES the BusinessProcess / Capability it would carry out. The
    connector→skill bridge: the background distiller writes it process→skill so
    reasoning relates an automation candidate to the descriptive process it
    addresses across any connected system.""" ;
    rdfs:range :BusinessProcess .

:canKG a owl:DatatypeProperty ;
    rdfs:domain :Model ;
    rdfs:range xsd:boolean .

:canRoute a owl:DatatypeProperty ;
    rdfs:domain :Model ;
    rdfs:range xsd:boolean .

:composes a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "composes" ;
    rdfs:comment """CONCEPT:KG-2.91 — a SkillWorkflowProposal COMPOSES the atomic
    Skills (or SkillProposals) it sequences as steps. Transitive so a workflow of
    workflows resolves to its leaf atomic skills under reasoning.""" ;
    rdfs:range :Skill .

:contextWindow a owl:DatatypeProperty ;
    rdfs:domain :Model ;
    rdfs:range xsd:integer .

:delegatesTo a owl:ObjectProperty ;
    rdfs:comment "Agent delegates to an external A2A agent." ;
    rdfs:domain :Agent .

:derives a owl:ObjectProperty ;
    rdfs:label "derives" ;
    rdfs:comment "CONCEPT:KG-2.91 — inverse of :derivedFrom (source node → the proposal distilled from it)." ;
    owl:inverseOf :derivedFrom .

:evolvedFrom a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:comment "Prompt lineage from evolution." ;
    rdfs:domain :Prompt ;
    rdfs:range :Prompt .

:executedProcess a owl:ObjectProperty ;
    rdfs:label "executedProcess" ;
    rdfs:comment """CONCEPT:ORCH-1.43 — a RunTrace (one workflow run) EXECUTED the
    descriptive BusinessProcess its workflow realizes (EXECUTED_PROCESS in the
    LPG; written by the workflow runner's lineage close-out when a REALIZES
    workflow completes). Closes the provenance loop opened by
    :realizesProcess.""" ;
    rdfs:range :BusinessProcess .

:goalText a owl:DatatypeProperty ;
    rdfs:range xsd:string .

:hasContext a owl:ObjectProperty ;
    rdfs:label "hasContext" ;
    rdfs:comment "CONCEPT:ORCH-1.39 — links a RunTrace (a spawned run) to the ContextBlob it consumed (provenance)." ;
    rdfs:range :ContextBlob .

:hasContextAnchor a owl:ObjectProperty ;
    rdfs:label "hasContext (anchor)" ;
    rdfs:comment "CONCEPT:ORCH-1.40 — Session -[:HAS_CONTEXT]-> ContextBlob anchor edge." ;
    rdfs:domain :Session ;
    rdfs:range :ContextBlob .

:hasMessage a owl:ObjectProperty ;
    rdfs:label "hasMessage" ;
    rdfs:comment "CONCEPT:ORCH-1.40 — Session -[:HAS_MESSAGE]-> AgentMessage durable-history edge." ;
    rdfs:domain :Session ;
    rdfs:range :AgentMessage .

:hasPrompt a owl:ObjectProperty ;
    rdfs:domain :Agent ;
    rdfs:range :Prompt .

:hasRun a owl:ObjectProperty ;
    rdfs:label "hasRun" ;
    rdfs:comment "CONCEPT:ORCH-1.40 — Session -[:HAS_RUN]-> RunTrace edge (spawned runs anchored to their session)." ;
    rdfs:domain :Session .

:hasSkill a owl:ObjectProperty ;
    rdfs:domain :Agent ;
    rdfs:range :Skill .

:intelligenceLevel a owl:DatatypeProperty ;
    rdfs:domain :Model ;
    rdfs:range xsd:string .

:memberOfTeam a owl:ObjectProperty ;
    rdfs:domain :Agent ;
    rdfs:range :Team .

:orchestrates a owl:ObjectProperty ;
    rdfs:comment "Workflow → the agents/skills it orchestrates." ;
    rdfs:domain :Workflow .

:realizesProcess a owl:ObjectProperty ;
    rdfs:label "realizesProcess" ;
    rdfs:comment """CONCEPT:ORCH-1.41 — a compiled executable Workflow REALIZES the
    descriptive BusinessProcess it was derived from (REALIZES in the LPG;
    written by the ProcessPlanCompiler). The bridge between the harvested
    process world (Camunda/Egeria/ArchiMate) and the executable workflow
    world, traversed by lineage close-out and provenance queries.""" ;
    rdfs:domain :Workflow ;
    rdfs:range :BusinessProcess .

:reportsTo a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:comment "Team reporting hierarchy (transitive)." ;
    rdfs:domain :Agent ;
    rdfs:range :Agent .

:solves a owl:ObjectProperty ;
    rdfs:comment "An Agent or Team that addresses a Goal." ;
    rdfs:range :Goal .

:systemPrompt a owl:DatatypeProperty ;
    rdfs:domain :Agent ;
    rdfs:range xsd:string .

:usesModel a owl:ObjectProperty ;
    rdfs:comment "The model an agent runs on, chosen by capability/complexity." ;
    rdfs:domain :Agent ;
    rdfs:range :Model .

:usesTool a owl:ObjectProperty ;
    rdfs:domain :Agent ;
    rdfs:range :Tool .

<http://knuckles.team/kg/orchestration> a owl:Ontology ;
    rdfs:label "Agent Intelligence Graph — Orchestration Module" ;
    rdfs:comment "Orchestration domain extension (skill proposals, workflow/process distillation). Imported by the canonical <http://knuckles.team/kg> ontology; resolved to ontology_orchestration.ttl by the local loader convention." .

:AgentMessage a owl:Class ;
    rdfs:label "AgentMessage" ;
    rdfs:comment "CONCEPT:ORCH-1.40 — a durable, replayable record of one message exchanged on an invoker↔spawned-agent channel (the live channel is in-RAM; this node is the durable record)." .

:Goal a owl:Class ;
    rdfs:label "Goal" .

:Team a owl:Class ;
    rdfs:label "Team" ;
    rdfs:comment "A hierarchical group of specialized agents for a goal." .

:Tool a owl:Class ;
    rdfs:label "Tool" .

:derivedFrom a owl:ObjectProperty ;
    rdfs:label "derived from" ;
    rdfs:comment """CONCEPT:KG-2.91 — provenance: a SkillProposal / SkillWorkflow
    proposal DERIVED_FROM the source system node (egeria/leanix/aris/camunda
    process or task) it was distilled from. Inverse of :derives so reasoning can
    walk source→proposal and proposal→source.""" .

:ContextBlob a owl:Class ;
    rdfs:label "ContextBlob" ;
    rdfs:comment "CONCEPT:ORCH-1.39 — curated context an invoking agent persists for a spawned agent to reference (session-scoped, optionally TTL'd)." .

:Skill a owl:Class ;
    rdfs:label "Skill" .

:Prompt a owl:Class ;
    rdfs:label "Prompt" .

:Session a owl:Class ;
    rdfs:label "Session" ;
    rdfs:comment "CONCEPT:ORCH-1.40 — id-addressable anchor (session:{sid}) for a session's collections; lets 'list by session' be a reliable single-hop traversal on a property-index-free engine." .

:Workflow a owl:Class ;
    rdfs:label "Workflow" ;
    rdfs:comment "An orchestration flow (skill-workflow) over agents/skills." .

:Model a owl:Class ;
    rdfs:label "Model" ;
    rdfs:comment "An LLM/embedding model the deployment serves, with capabilities (from config.json) used to choose the right model per task." .

:Agent a owl:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "A synthesized or registered agent (prompt + tools + skills)." .


# ── Unified scheduling / task / loop engine (CONCEPT:OS-5.44 / KG-2.113 / KG-2.114) ──
# Reuses :Task (ontology_quant.ttl) and :dependsOn (ontology.ttl, Task→Task). Models
# the collapse of the four legacy scheduling surfaces into ONE :Schedule concept, and
# the typed relationships of the hardened priority+scheduled queue, so OWL/RDF reasoning
# extrapolates across the scheduling/loop/queue plane like the rest of the ecosystem.

:Schedule a owl:Class ;
    rdfs:label "Schedule" ;
    rdfs:seeAlso prov:Activity ;
    rdfs:comment """CONCEPT:OS-5.44 — a durable recurring-job specification
    (cron | interval | adaptive) the ONE unified scheduler evaluates; when due it
    enqueues a scheduled_job Task onto the priority+scheduled queue. Subsumes the
    former fixed-interval maintenance ticks, the static deploy/schedules.yml cron,
    the loop-cycle tick, and the legacy MaintenanceCron — one scheduling concept.""" .

:Loop a owl:Class ;
    rdfs:label "Loop" ;
    rdfs:seeAlso prov:Activity ;
    rdfs:comment """CONCEPT:KG-2.78 — a long-running objective (research|develop|skill)
    the LoopController advances through one hot path; carries a priority bucket and may
    enqueue prioritized child Tasks.""" .

:DeadLetterTask a owl:Class ;
    rdfs:subClassOf :Task ;
    rdfs:label "Dead-Letter Task" ;
    rdfs:comment """CONCEPT:KG-2.113 — a Task that exhausted its application-level
    retries (distinct from a crash-requeue failure); parked for triage, never silently
    dropped.""" .

:schedules a owl:ObjectProperty ;
    rdfs:label "schedules" ;
    rdfs:domain :Schedule ;
    rdfs:range :Task ;
    rdfs:comment "CONCEPT:OS-5.44 — a Schedule SCHEDULES the scheduled_job Task it enqueues when due." ;
    owl:inverseOf :scheduledBy .

:scheduledBy a owl:ObjectProperty ;
    rdfs:label "scheduled by" ;
    rdfs:domain :Task ;
    rdfs:range :Schedule .

:enqueues a owl:ObjectProperty ;
    rdfs:label "enqueues" ;
    rdfs:range :Task ;
    rdfs:comment "CONCEPT:KG-2.113 — a Schedule or Loop ENQUEUES a Task onto the unified queue." ;
    owl:inverseOf :enqueuedBy .

:enqueuedBy a owl:ObjectProperty ;
    rdfs:label "enqueued by" ;
    rdfs:domain :Task .

:childTaskOf a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "child task of" ;
    rdfs:domain :Task ;
    rdfs:range :Loop ;
    rdfs:comment "CONCEPT:KG-2.113 — a Task spawned by a Loop stage (transitive across a fan-out tree)." .

:deadLetters a owl:ObjectProperty ;
    rdfs:label "dead-letters" ;
    rdfs:range :DeadLetterTask ;
    rdfs:comment "CONCEPT:KG-2.113 — links the unified queue to a poison Task parked after exhausting retries." .

:dueAt a owl:DatatypeProperty ;
    rdfs:label "due at" ;
    rdfs:domain :Task ;
    rdfs:range xsd:dateTime ;
    rdfs:comment """CONCEPT:KG-2.113 — the earliest time a delayed/retrying Task becomes
    runnable (eta). A NEW datatype property, deliberately distinct from the object-property
    :scheduledFor (CalendarEvent→Person) which must not be overloaded.""" .

:prioBucket a owl:DatatypeProperty ;
    rdfs:label "priority bucket" ;
    rdfs:range xsd:integer ;
    rdfs:comment "CONCEPT:KG-2.113 — discrete claim/intake priority 0 (critical) .. 3 (background) for a Task, Schedule, or Loop." .

:attempts a owl:DatatypeProperty ;
    rdfs:label "attempts" ;
    rdfs:domain :Task ;
    rdfs:range xsd:integer ;
    rdfs:comment "CONCEPT:KG-2.113 — application-level retry count; at :maxAttempts the Task becomes a :DeadLetterTask." .

:maxAttempts a owl:DatatypeProperty ;
    rdfs:label "max attempts" ;
    rdfs:domain :Task ;
    rdfs:range xsd:integer .
