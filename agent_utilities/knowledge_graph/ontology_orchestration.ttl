@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:BusTopicCursor a owl:Class ;
    rdfs:label "BusTopicCursor" ;
    rdfs:comment """CONCEPT:ECO-4.91 â€” a per-(BusAgent, Topic) replay cursor for store-and-forward
    topic messages: a dedicated node (never a property on the shared Topic, which the backend's
    upsert would clobber) so each agent reads each stored topic message at most once.""" .

:SkillProposal a owl:Class ;
    rdfs:label "Skill Proposal" ;
    rdfs:comment "CONCEPT:KG-2.90 â€” a propose-only atomic-skill candidate the background distiller synthesizes from a mapped process/task of any connected system; reviewed+approved by a human before it materializes." .

:SkillWorkflowProposal a owl:Class ;
    rdfs:label "Skill Workflow Proposal" ;
    rdfs:comment "CONCEPT:KG-2.90 â€” a propose-only skill-workflow candidate (composes atomic Skills) distilled from a flowsTo-chain of business tasks." ;
    rdfs:subClassOf :Workflow .

:attempts a owl:DatatypeProperty ;
    rdfs:label "attempts" ;
    rdfs:comment "CONCEPT:KG-2.113 â€” application-level retry count; at :maxAttempts the Task becomes a :DeadLetterTask." ;
    rdfs:domain :Task ;
    rdfs:range xsd:integer .

:automates a owl:ObjectProperty ;
    rdfs:label "automates" ;
    rdfs:comment """CONCEPT:KG-2.91 â€” a synthesized Skill / SkillWorkflow (or its
    proposal) AUTOMATES the BusinessProcess / Capability it would carry out. The
    connectorâ†’skill bridge: the background distiller writes it processâ†’skill so
    reasoning relates an automation candidate to the descriptive process it
    addresses across any connected system.""" ;
    rdfs:range :BusinessProcess .

:canKG a owl:DatatypeProperty ;
    rdfs:domain :Model ;
    rdfs:range xsd:boolean .

:canRoute a owl:DatatypeProperty ;
    rdfs:domain :Model ;
    rdfs:range xsd:boolean .

:childTaskOf a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "child task of" ;
    rdfs:comment "CONCEPT:KG-2.113 â€” a Task spawned by a Loop stage (transitive across a fan-out tree)." ;
    rdfs:domain :Task ;
    rdfs:range :Loop .

:composes a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "composes" ;
    rdfs:comment """CONCEPT:KG-2.91 â€” a SkillWorkflowProposal COMPOSES the atomic
    Skills (or SkillProposals) it sequences as steps. Transitive so a workflow of
    workflows resolves to its leaf atomic skills under reasoning.""" ;
    rdfs:range :Skill .

:contextWindow a owl:DatatypeProperty ;
    rdfs:domain :Model ;
    rdfs:range xsd:integer .

:deadLetters a owl:ObjectProperty ;
    rdfs:label "dead-letters" ;
    rdfs:comment "CONCEPT:KG-2.113 â€” links the unified queue to a poison Task parked after exhausting retries." ;
    rdfs:range :DeadLetterTask .

:delegatesTo a owl:ObjectProperty ;
    rdfs:comment "Agent delegates to an external A2A agent." ;
    rdfs:domain :Agent .

:derives a owl:ObjectProperty ;
    rdfs:label "derives" ;
    rdfs:comment "CONCEPT:KG-2.91 â€” inverse of :derivedFrom (source node â†’ the proposal distilled from it)." ;
    owl:inverseOf :derivedFrom .

:dueAt a owl:DatatypeProperty ;
    rdfs:label "due at" ;
    rdfs:comment """CONCEPT:KG-2.113 â€” the earliest time a delayed/retrying Task becomes
    runnable (eta). A NEW datatype property, deliberately distinct from the object-property
    :scheduledFor (CalendarEventâ†’Person) which must not be overloaded.""" ;
    rdfs:domain :Task ;
    rdfs:range xsd:dateTime .

:enqueues a owl:ObjectProperty ;
    rdfs:label "enqueues" ;
    rdfs:comment "CONCEPT:KG-2.113 â€” a Schedule or Loop ENQUEUES a Task onto the unified queue." ;
    rdfs:range :Task ;
    owl:inverseOf :enqueuedBy .

:evolvedFrom a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:comment "Prompt lineage from evolution." ;
    rdfs:domain :Prompt ;
    rdfs:range :Prompt .

:executedProcess a owl:ObjectProperty ;
    rdfs:label "executedProcess" ;
    rdfs:comment """CONCEPT:ORCH-1.43 â€” a RunTrace (one workflow run) EXECUTED the
    descriptive BusinessProcess its workflow realizes (EXECUTED_PROCESS in the
    LPG; written by the workflow runner's lineage close-out when a REALIZES
    workflow completes). Closes the provenance loop opened by
    :realizesProcess.""" ;
    rdfs:range :BusinessProcess .

:goalText a owl:DatatypeProperty ;
    rdfs:range xsd:string .

:hasBusMessage a owl:ObjectProperty ;
    rdfs:label "hasBusMessage" ;
    rdfs:comment "CONCEPT:KG-2.141 â€” BusAgent -[:HAS_BUS_MESSAGE]-> BusMessage: a participant's durable bus inbox edge (ECO-4.84)." ;
    rdfs:domain :BusAgent ;
    rdfs:range :BusMessage .

:hasContext a owl:ObjectProperty ;
    rdfs:label "hasContext" ;
    rdfs:comment "CONCEPT:ORCH-1.39 â€” links a RunTrace (a spawned run) to the ContextBlob it consumed (provenance)." ;
    rdfs:range :ContextBlob .

:hasContextAnchor a owl:ObjectProperty ;
    rdfs:label "hasContext (anchor)" ;
    rdfs:comment "CONCEPT:ORCH-1.40 â€” Session -[:HAS_CONTEXT]-> ContextBlob anchor edge." ;
    rdfs:domain :Session ;
    rdfs:range :ContextBlob .

:hasMessage a owl:ObjectProperty ;
    rdfs:label "hasMessage" ;
    rdfs:comment "CONCEPT:ORCH-1.40 â€” Session -[:HAS_MESSAGE]-> AgentMessage durable-history edge." ;
    rdfs:domain :Session ;
    rdfs:range :AgentMessage .

:hasPrompt a owl:ObjectProperty ;
    rdfs:domain :Agent ;
    rdfs:range :Prompt .

:hasRun a owl:ObjectProperty ;
    rdfs:label "hasRun" ;
    rdfs:comment "CONCEPT:ORCH-1.40 â€” Session -[:HAS_RUN]-> RunTrace edge (spawned runs anchored to their session)." ;
    rdfs:domain :Session .

:hasSkill a owl:ObjectProperty ;
    rdfs:domain :Agent ;
    rdfs:range :Skill .

:intelligenceLevel a owl:DatatypeProperty ;
    rdfs:domain :Model ;
    rdfs:range xsd:string .

:lastSeen a owl:DatatypeProperty ;
    rdfs:label "last seen" ;
    rdfs:comment "CONCEPT:KG-2.141 â€” unix timestamp of a BusAgent's most recent heartbeat on the bus (ECO-4.84)." ;
    rdfs:domain :BusAgent ;
    rdfs:range xsd:double .

:maxAttempts a owl:DatatypeProperty ;
    rdfs:label "max attempts" ;
    rdfs:domain :Task ;
    rdfs:range xsd:integer .

:memberOfTeam a owl:ObjectProperty ;
    rdfs:domain :Agent ;
    rdfs:range :Team .

:orchestrates a owl:ObjectProperty ;
    rdfs:comment "Workflow â†’ the agents/skills it orchestrates." ;
    rdfs:domain :Workflow .

:presenceStatus a owl:DatatypeProperty ;
    rdfs:label "presence status" ;
    rdfs:comment "CONCEPT:KG-2.141 â€” a BusAgent's bus presence (online|offline), computed from lastSeen vs a staleness window (ECO-4.84)." ;
    rdfs:domain :BusAgent ;
    rdfs:range xsd:string .

:prioBucket a owl:DatatypeProperty ;
    rdfs:label "priority bucket" ;
    rdfs:comment "CONCEPT:KG-2.113 â€” discrete claim/intake priority 0 (critical) .. 3 (background) for a Task, Schedule, or Loop." ;
    rdfs:range xsd:integer .

:realizesProcess a owl:ObjectProperty ;
    rdfs:label "realizesProcess" ;
    rdfs:comment """CONCEPT:ORCH-1.41 â€” a compiled executable Workflow REALIZES the
    descriptive BusinessProcess it was derived from (REALIZES in the LPG;
    written by the ProcessPlanCompiler). The bridge between the harvested
    process world (Camunda/Egeria/ArchiMate) and the executable workflow
    world, traversed by lineage close-out and provenance queries.""" ;
    rdfs:domain :Workflow ;
    rdfs:range :BusinessProcess .

:reportsTo a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:comment "Team reporting hierarchy (transitive)." ;
    rdfs:domain :Agent ;
    rdfs:range :Agent .

:schedules a owl:ObjectProperty ;
    rdfs:label "schedules" ;
    rdfs:comment "CONCEPT:OS-5.44 â€” a Schedule SCHEDULES the scheduled_job Task it enqueues when due." ;
    rdfs:domain :Schedule ;
    rdfs:range :Task ;
    owl:inverseOf :scheduledBy .

:solves a owl:ObjectProperty ;
    rdfs:comment "An Agent or Team that addresses a Goal." ;
    rdfs:range :Goal .

:subscribesToTopic a owl:ObjectProperty ;
    rdfs:label "subscribesToTopic" ;
    rdfs:comment "CONCEPT:KG-2.141 â€” BusSubscription -> the Topic it subscribes a BusAgent to (ECO-4.84)." ;
    rdfs:domain :BusSubscription ;
    rdfs:range :Topic .

:systemPrompt a owl:DatatypeProperty ;
    rdfs:domain :Agent ;
    rdfs:range xsd:string .

:usesModel a owl:ObjectProperty ;
    rdfs:comment "The model an agent runs on, chosen by capability/complexity." ;
    rdfs:domain :Agent ;
    rdfs:range :Model .

:usesTool a owl:ObjectProperty ;
    rdfs:domain :Agent ;
    rdfs:range :Tool .

<http://knuckles.team/kg/orchestration> a owl:Ontology ;
    rdfs:label "Agent Intelligence Graph â€” Orchestration Module" ;
    rdfs:comment "Orchestration domain extension (skill proposals, workflow/process distillation). Imported by the canonical <http://knuckles.team/kg> ontology; resolved to ontology_orchestration.ttl by the local loader convention." .

:AgentMessage a owl:Class ;
    rdfs:label "AgentMessage" ;
    rdfs:comment "CONCEPT:ORCH-1.40 â€” a durable, replayable record of one message exchanged on an invokerâ†”spawned-agent channel (the live channel is in-RAM; this node is the durable record)." .

:BusMessage a owl:Class ;
    rdfs:label "BusMessage" ;
    rdfs:comment """CONCEPT:KG-2.141 â€” a durable agent-to-agent bus message delivered to one
    recipient Agent (the AgentBus mailbox record, ECO-4.84). A topic fan-out writes one
    BusMessage per recipient sharing a msg_group, so a federation relay can dedup across hubs.
    Store-and-forward (CONCEPT:ECO-4.91) also writes a topic-log variant (recipient="",
    kind="topic", expires_at) replayed to late subscribers via a BusTopicCursor.""" .

:BusSubscription a owl:Class ;
    rdfs:label "BusSubscription" ;
    rdfs:comment """CONCEPT:KG-2.141 â€” a BusAgent's subscription to a Topic, modeled as a node
    (not an edge) so membership resolves in one hop on every backend (ECO-4.84).""" .

:DeadLetterTask a owl:Class ;
    rdfs:label "Dead-Letter Task" ;
    rdfs:comment """CONCEPT:KG-2.113 â€” a Task that exhausted its application-level
    retries (distinct from a crash-requeue failure); parked for triage, never silently
    dropped.""" ;
    rdfs:subClassOf :Task .

:Goal a owl:Class ;
    rdfs:label "Goal" .

:Loop a owl:Class ;
    rdfs:label "Loop" ;
    rdfs:comment """CONCEPT:KG-2.78 â€” a long-running objective (research|develop|skill)
    the LoopController advances through one hot path; carries a priority bucket and may
    enqueue prioritized child Tasks.""" ;
    rdfs:seeAlso prov:Activity .

:Team a owl:Class ;
    rdfs:label "Team" ;
    rdfs:comment "A hierarchical group of specialized agents for a goal." .

:Tool a owl:Class ;
    rdfs:label "Tool" .

:Topic a owl:Class ;
    rdfs:label "Topic" ;
    rdfs:comment "CONCEPT:KG-2.141 â€” a named pub/sub channel on the AgentBus that BusAgents subscribe to (ECO-4.84)." .

:derivedFrom a owl:ObjectProperty ;
    rdfs:label "derived from" ;
    rdfs:comment """CONCEPT:KG-2.91 â€” provenance: a SkillProposal / SkillWorkflow
    proposal DERIVED_FROM the source system node (egeria/leanix/aris/camunda
    process or task) it was distilled from. Inverse of :derives so reasoning can
    walk sourceâ†’proposal and proposalâ†’source.""" .

:enqueuedBy a owl:ObjectProperty ;
    rdfs:label "enqueued by" ;
    rdfs:domain :Task .

:scheduledBy a owl:ObjectProperty ;
    rdfs:label "scheduled by" ;
    rdfs:domain :Task ;
    rdfs:range :Schedule .

:ContextBlob a owl:Class ;
    rdfs:label "ContextBlob" ;
    rdfs:comment "CONCEPT:ORCH-1.39 â€” curated context an invoking agent persists for a spawned agent to reference (session-scoped, optionally TTL'd)." .

:Schedule a owl:Class ;
    rdfs:label "Schedule" ;
    rdfs:comment """CONCEPT:OS-5.44 â€” a durable recurring-job specification
    (cron | interval | adaptive) the ONE unified scheduler evaluates; when due it
    enqueues a scheduled_job Task onto the priority+scheduled queue. Subsumes the
    former fixed-interval maintenance ticks, the static deploy/schedules.yml cron,
    the loop-cycle tick, and the legacy MaintenanceCron â€” one scheduling concept.""" ;
    rdfs:seeAlso prov:Activity .

:Skill a owl:Class ;
    rdfs:label "Skill" .

:BusAgent a owl:Class ;
    rdfs:label "BusAgent" ;
    rdfs:comment """CONCEPT:KG-2.141 â€” a participant on the AgentBus (a session: Claude/other-LLM/
    any provider, any host), with presence + capabilities (ECO-4.84). A dedicated class (not the
    typed orchestration :Agent) so bus props land in the generic node store across backends.""" .

:Prompt a owl:Class ;
    rdfs:label "Prompt" .

:Session a owl:Class ;
    rdfs:label "Session" ;
    rdfs:comment "CONCEPT:ORCH-1.40 â€” id-addressable anchor (session:{sid}) for a session's collections; lets 'list by session' be a reliable single-hop traversal on a property-index-free engine." .

:Workflow a owl:Class ;
    rdfs:label "Workflow" ;
    rdfs:comment "An orchestration flow (skill-workflow) over agents/skills." .

:Model a owl:Class ;
    rdfs:label "Model" ;
    rdfs:comment "An LLM/embedding model the deployment serves, with capabilities (from config.json) used to choose the right model per task." .

:Agent a owl:Class ;
    rdfs:label "Agent" ;
    rdfs:comment "A synthesized or registered agent (prompt + tools + skills)." .

# ---------------------------------------------------------------------------
# Agent-native run version-control (run-VCS) â€” the shepherd assimilation. Elevates
# the observe-only :RunTrace/:ToolCall provenance into a content-addressed, typed,
# projectable, forkable, revertable run history (CONCEPT:AU-ORCH.runvcs.event-kernel).
# ---------------------------------------------------------------------------

:RunTrace a owl:Class ;
    rdfs:label "RunTrace" ;
    rdfs:comment """CONCEPT:AU-ORCH.runvcs.event-kernel â€” one agent run, now the root of a
    content-addressed, typed run-event log (not just an observe-only action chain). Owns an
    ordered :RunEvent path plus the :RunCommit history a fork/revert branches from.""" ;
    rdfs:seeAlso prov:Activity .

:RunEvent a owl:Class ;
    rdfs:label "RunEvent" ;
    rdfs:comment """CONCEPT:AU-ORCH.runvcs.event-kernel â€” one typed, content-addressed run event
    (shepherd Fact shape). Its :recordDigest IS its identity (record_id == digest over
    schema_ref+mode+payload+causality), so identical events dedup and replay is reproducible.
    :recordMode is a declaration (intent) or a capture (observed outcome).""" ;
    rdfs:seeAlso prov:Entity .

:RunCommit a owl:Class ;
    rdfs:label "RunCommit" ;
    rdfs:comment """CONCEPT:AU-ORCH.runvcs.run-commit â€” ONE content-addressed commit binding a
    message checkpoint + an :FsSnapshot + a :RunCut (the process/event frontier) so a run's
    conversation, files, and effects revert together as one exact world.""" ;
    rdfs:seeAlso prov:Entity .

:RunCut a owl:Class ;
    rdfs:label "RunCut" ;
    rdfs:comment """CONCEPT:AU-ORCH.runvcs.event-kernel â€” an immutable frontier over a run's
    event log ('the run through ordinal N', shepherd Cut); the causal prefix a fork/revert
    restores to.""" .

:FsSnapshot a owl:Class ;
    rdfs:label "FsSnapshot" ;
    rdfs:comment """CONCEPT:AU-ORCH.runvcs.run-commit â€” a content-addressed copy-on-write
    snapshot of a run's workspace filesystem (overlayfs/fuse-overlayfs accelerated, blob-store
    fallback); the fs half of a :RunCommit's exact-world restore.""" .

:RetainedRunProposal a owl:Class ;
    rdfs:label "Retained Run Proposal" ;
    rdfs:comment """CONCEPT:AU-ORCH.runvcs.retained-output-gate â€” a completed run's world delta
    (its final :RunCommit + any KG edits) HELD as a proposal, materialized into the real world
    only when the run.select action-policy gate accepts; discard leaves the world untouched.""" ;
    rdfs:subClassOf :SkillProposal .

:hasEvent a owl:ObjectProperty ;
    rdfs:label "has event" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.event-kernel â€” RunTrace -[:HAS_EVENT]-> RunEvent (a run owns its ordered event path)." ;
    rdfs:domain :RunTrace ;
    rdfs:range :RunEvent .

:causedByEvent a owl:ObjectProperty ;
    rdfs:label "caused by event" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.event-kernel â€” RunEvent -[:CAUSED_BY]-> RunEvent: the causality edge threading the content-addressed event DAG." ;
    rdfs:domain :RunEvent ;
    rdfs:range :RunEvent .

:hasCommit a owl:ObjectProperty ;
    rdfs:label "has commit" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.run-commit â€” RunTrace -[:HAS_COMMIT]-> RunCommit (a run's commit history)." ;
    rdfs:domain :RunTrace ;
    rdfs:range :RunCommit .

:forkedFrom a owl:ObjectProperty ;
    rdfs:label "forked from" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.fork-revert â€” a child RunTrace -[:FORKED_FROM]-> the RunCommit it branched off (lineage of a live-run fork)." ;
    rdfs:domain :RunTrace ;
    rdfs:range :RunCommit .

:snapshots a owl:ObjectProperty ;
    rdfs:label "snapshots" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.run-commit â€” RunCommit -[:SNAPSHOTS]-> FsSnapshot (the filesystem captured by a commit)." ;
    rdfs:domain :RunCommit ;
    rdfs:range :FsSnapshot .

:proposesCommit a owl:ObjectProperty ;
    rdfs:label "proposes commit" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.retained-output-gate â€” RetainedRunProposal -[:PROPOSES_COMMIT]-> the RunCommit it would materialize on accept." ;
    rdfs:domain :RetainedRunProposal ;
    rdfs:range :RunCommit .

:recordDigest a owl:DatatypeProperty ;
    rdfs:label "record digest" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.event-kernel â€” the content hash that is a RunEvent's identity (record_id == digest)." ;
    rdfs:domain :RunEvent ;
    rdfs:range xsd:string .

:recordMode a owl:DatatypeProperty ;
    rdfs:label "record mode" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.trace-replay â€” a RunEvent's mode: 'declaration' (intent) or 'capture' (observed outcome); the split that makes a recorded exchange stand in for the model on replay." ;
    rdfs:domain :RunEvent ;
    rdfs:range xsd:string .

:eventOrdinal a owl:DatatypeProperty ;
    rdfs:label "event ordinal" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.event-kernel â€” a RunEvent's append position in its run's path (view metadata, not identity)." ;
    rdfs:domain :RunEvent ;
    rdfs:range xsd:integer .

:commitId a owl:DatatypeProperty ;
    rdfs:label "commit id" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.run-commit â€” a RunCommit's content-addressed id (digest of checkpoint+fs-snapshot+cut)." ;
    rdfs:domain :RunCommit ;
    rdfs:range xsd:string .

:snapshotId a owl:DatatypeProperty ;
    rdfs:label "snapshot id" ;
    rdfs:comment "CONCEPT:AU-ORCH.runvcs.run-commit â€” an FsSnapshot's content-addressed id (digest of its file manifest)." ;
    rdfs:domain :FsSnapshot ;
    rdfs:range xsd:string .

