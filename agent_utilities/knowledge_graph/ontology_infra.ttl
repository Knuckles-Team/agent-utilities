@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:HardwareNode a owl:Class ;
    rdfs:label "Hardware Node" ;
    rdfs:comment """A physical machine providing compute capacity. Every
    HardwareNode is a Server, but not every Server is bare metal.""" ;
    rdfs:subClassOf :Server .

:runsOn a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "runs on" ;
    rdfs:comment """Links a Service to the Server it is scheduled on. Declared
    transitive so derived placement (Service → Server → containing node) can be
    inferred for blast-radius queries.""" ;
    rdfs:domain :Service ;
    rdfs:range :Server .

<http://knuckles.team/kg/infra> a owl:Ontology ;
    rdfs:label "Infrastructure Ontology" ;
    rdfs:comment """Physical and runtime substrate of the Enterprise OS:
    inventory hosts (Servers / HardwareNodes) and the Docker Services that run
    on them. Enables blast-radius and placement reasoning over the KG.

    CONCEPT:KG-2.9 — Infrastructure blast-radius (inventory + Docker services)""" ;
    owl:imports <http://knuckles.team/kg> .

:Service a owl:Class ;
    rdfs:label "Service" ;
    rdfs:comment """A Docker service / containerised workload, identified by
    image and replica count, scheduled onto one or more Servers.""" .

:Server a owl:Class ;
    rdfs:label "Server" ;
    rdfs:comment """An inventory host that can run workloads (a tunnel-manager
    inventory.yaml entry). Carries hostname, ip, roles and groups.""" .

