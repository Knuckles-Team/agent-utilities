@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bfo:    <http://purl.obolibrary.org/obo/BFO_> .
@prefix schema: <http://schema.org/> .

<http://knuckles.team/kg/medical> a owl:Ontology ;
    owl:imports <http://knuckles.team/kg> ;
    rdfs:label "Medical & Healthcare Ontology" ;
    rdfs:comment """Healthcare domain ontology. Provides BFO-aligned classes for
clinical concepts, patient management, and research trials.
Aligned to SNOMED-CT, ICD-10/11, LOINC, RxNorm, HL7 FHIR, CDISC.""" .

# =====================================================================
# Medical Core Classes (CONCEPT:KG-2.8)
# =====================================================================

:Patient a owl:Class ;
    rdfs:subClassOf :Person ;
    rdfs:label "Patient" ;
    rdfs:comment """A person receiving medical care. Extends Person with PHI-protected
attributes. HIPAA §164.312 technical safeguards apply.""" .

:ClinicalCondition a owl:Class ;
    rdfs:subClassOf bfo:0000020 ;
    rdfs:label "Clinical Condition" ;
    rdfs:comment "A diagnosed medical condition. BFO:SpecificallyDependentContinuant. Aligned to SNOMED-CT." .

:Medication a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Medication" ;
    rdfs:comment "A prescribed or administered drug. BFO:GDC. Aligned to RxNorm." .

:ClinicalTrial a owl:Class ;
    rdfs:subClassOf :Experiment ;
    rdfs:label "Clinical Trial" ;
    rdfs:comment "A medical research trial. Extends Experiment. Aligned to CDISC/CDASH." .

:DiagnosisCode a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Diagnosis Code" ;
    rdfs:comment "An ICD-10/11 diagnosis classification code. BFO:GDC." .

:CarePathway a owl:Class ;
    rdfs:subClassOf :Procedure ;
    rdfs:label "Care Pathway" ;
    rdfs:comment "A clinical guideline as an executable process flow. BFO:Process via Procedure." .

:ConsentRecord a owl:Class ;
    rdfs:subClassOf bfo:0000031 ;
    rdfs:label "Consent Record" ;
    rdfs:comment "Granular patient consent with temporal validity. Aligned to HL7 FHIR Consent." .

:LabResult a owl:Class ;
    rdfs:subClassOf :Observation ;
    rdfs:label "Lab Result" ;
    rdfs:comment "A laboratory test result. Subclass of Observation. Aligned to LOINC." .

# =====================================================================
# Medical Object Properties (CONCEPT:KG-2.8)
# =====================================================================

:diagnosedWith a owl:ObjectProperty ;
    rdfs:domain :Patient ; rdfs:range :ClinicalCondition ;
    rdfs:label "diagnosed with" .

:prescribedMedication a owl:ObjectProperty ;
    rdfs:domain :Patient ; rdfs:range :Medication ;
    rdfs:label "prescribed medication" .

:contraindicatedWith a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain :Medication ; rdfs:range :Medication ;
    rdfs:label "contraindicated with" ;
    rdfs:comment "Symmetric drug-drug contraindication." .

:enrolledIn a owl:ObjectProperty ;
    rdfs:domain :Patient ; rdfs:range :ClinicalTrial ;
    rdfs:label "enrolled in" .

:hasConsent a owl:ObjectProperty ;
    rdfs:domain :Patient ; rdfs:range :ConsentRecord ;
    rdfs:label "has consent" .

:followsPathway a owl:ObjectProperty ;
    rdfs:domain :Patient ; rdfs:range :CarePathway ;
    rdfs:label "follows pathway" .

:codedAs a owl:ObjectProperty ;
    rdfs:domain :ClinicalCondition ; rdfs:range :DiagnosisCode ;
    rdfs:label "coded as" .

# =====================================================================
# Medical Datatype Properties (CONCEPT:KG-2.8)
# =====================================================================

:icdCode a owl:DatatypeProperty ;
    rdfs:domain :DiagnosisCode ; rdfs:range xsd:string ;
    rdfs:label "ICD code" .

:snomedId a owl:DatatypeProperty ;
    rdfs:domain :ClinicalCondition ; rdfs:range xsd:string ;
    rdfs:label "SNOMED CT id" .

:rxnormCui a owl:DatatypeProperty ;
    rdfs:domain :Medication ; rdfs:range xsd:string ;
    rdfs:label "RxNorm CUI" .

:consentScope a owl:DatatypeProperty ;
    rdfs:domain :ConsentRecord ; rdfs:range xsd:string ;
    rdfs:label "consent scope" ;
    rdfs:comment "Scope of consent: treatment, research, data_sharing." .

:consentValidUntil a owl:DatatypeProperty ;
    rdfs:domain :ConsentRecord ; rdfs:range xsd:date ;
    rdfs:label "consent valid until" .

:trialPhase a owl:DatatypeProperty ;
    rdfs:domain :ClinicalTrial ; rdfs:range xsd:string ;
    rdfs:label "trial phase" ;
    rdfs:comment "Phase I, II, III, or IV." .
