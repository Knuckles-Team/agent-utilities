:DeptAdmin a :Department ;
    rdfs:label "Admin" ;
    :hasAgentRole :AgentAgentSummary,
        :AgentAuditImplementationAgainstSpecification,
        :AgentBaseAgent,
        :AgentBrowserAutomation,
        :AgentCritique,
        :AgentDecomposeUserRequestsIntoHigh-FidelityTasks,
        :AgentDesignHigh-FidelityExecutionPlans,
        :AgentFitnessTrainer,
