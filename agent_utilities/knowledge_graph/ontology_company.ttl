        :AgentMemoryInstruction,
        :AgentMemorySelection,
        :AgentPythonProgrammer,
        :AgentSafetyGuard,
        :AgentSafetyPolicy,
        :AgentToolGuidance,
        :AgentWriteCode .

:DeptEngineering a :Department ;
    rdfs:label "Engineering" ;
    :hasAgentRole :AgentAgentEngineer,
        :AgentCProgrammer,
        :AgentCloudArchitect,
        :AgentCppProgrammer,
