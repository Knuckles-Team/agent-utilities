@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:Topic a owl:Class ;
    rdfs:label "Topic" ;
    rdfs:comment "A message/stream topic (e.g. Kafka) carrying events between services." ;
    rdfs:subClassOf :DataSource .

<http://knuckles.team/kg/observability> a owl:Ontology ;
    rdfs:label "Observability & Streaming Ontology" ;
    rdfs:comment "Ops/observability node types (CONCEPT:KG-2.9)." ;
    owl:imports <http://knuckles.team/kg> .

