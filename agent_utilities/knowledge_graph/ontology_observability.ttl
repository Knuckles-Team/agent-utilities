@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:Generation a owl:Class ;
    rdfs:label "LLM Generation" ;
    rdfs:comment """A Langfuse generation: an LLM-call observation (model + prompt + output)
that is part_of a :Trace. A specialization of :Observation (CONCEPT:KG-2.156).""" ;
    rdfs:subClassOf :Observation .

:HeartbeatStat a owl:Class ;
    rdfs:label "Heartbeat Stat" ;
    rdfs:comment """A single Uptime-Kuma heartbeat sample (up/down + ping) part_of a
:UptimeMonitor — the substrate for failure-pattern analysis (CONCEPT:KG-2.159).""" ;
    rdfs:subClassOf :Observation .

:Topic a owl:Class ;
    rdfs:label "Topic" ;
    rdfs:comment "A message/stream topic (e.g. Kafka) carrying events between services." ;
    rdfs:subClassOf :DataSource .

:Trace a owl:Class ;
    rdfs:label "LLM Trace" ;
    rdfs:comment """A Langfuse trace: one end-to-end LLM application invocation grouping
its :Observation / :Generation steps (CONCEPT:KG-2.156).""" ;
    rdfs:subClassOf :Episode .

:UptimeMonitor a owl:Class ;
    rdfs:label "Uptime Monitor" ;
    rdfs:comment """An Uptime-Kuma monitor (an availability probe of a service/URL) whose
samples are :HeartbeatStat (CONCEPT:KG-2.159).""" ;
    rdfs:subClassOf :System .

<http://knuckles.team/kg/observability> a owl:Ontology ;
    rdfs:label "Observability & Streaming Ontology" ;
    rdfs:comment "Ops/observability node types (CONCEPT:KG-2.9 / KG-2.156 / KG-2.159)." ;
    owl:imports <http://knuckles.team/kg> .

