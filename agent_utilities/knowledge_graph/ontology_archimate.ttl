@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:BusinessTask a owl:Class ;
    rdfs:label "Business Task" ;
    rdfs:comment """A unit of business behaviour within a process (e.g. a Camunda
    user/service task). A BusinessTask is part of a BusinessProcess.""" ;
    rdfs:subClassOf :BusinessProcess .

:Change rdfs:subClassOf :BusinessProcess .

:Customer rdfs:subClassOf :BusinessActor .

:Employee rdfs:subClassOf :BusinessActor .

:Incident rdfs:subClassOf :ApplicationEvent ;
    owl:equivalentClass :ErpNextIssue .

:Person rdfs:subClassOf :BusinessActor .

:Playbook rdfs:subClassOf :BusinessProcess .

<http://knuckles.team/kg/archimate> a owl:Ontology ;
    rdfs:label "ArchiMate Canonical Upper Ontology & Vendor Crosswalk" ;
    rdfs:comment """Vendor-neutral ArchiMate 3.2 anchor concepts plus the
    cross-vendor crosswalk that makes enterprise systems interchangeable at the
    reasoning level. Each per-system class (ServiceNow :Incident, ERPNext
    :ErpNextIssue, Camunda :BusinessProcess/:BusinessTask, ...) is related by
    rdfs:subClassOf / owl:equivalentClass to one canonical concept, so a single
    SPARQL/Cypher query resolves all sources regardless of which vendor tool a
    client runs. Reasoning (owlready2/HermiT via core/owl_bridge.py) propagates
    rdf:type along these axioms onto the canonical concepts.

    All classes share the single namespace http://knuckles.team/kg# — this file
    only DEFINES classes not declared elsewhere (:ApplicationEvent, :BusinessTask,
    :BusinessActor) and ADDS crosswalk axioms onto classes defined in sibling
    ontologies (:Incident/:Change in ontology_servicenow.ttl;
    :Employee/:Customer/:ErpNextIssue in ontology_erpnext.ttl;
    :BusinessProcess/:ApplicationComponent in ontology_quant.ttl;
    :BusinessCapability in ontology_leanix.ttl). It never redefines them.

    CONCEPT:KG-2.9 — Enterprise OS vendor-neutral ontology.""" ;
    owl:imports <http://knuckles.team/kg> .

:ErpNextIssue rdfs:subClassOf :ApplicationEvent .

:ApplicationEvent a owl:Class ;
    rdfs:label "Application Event" ;
    rdfs:comment """Canonical ArchiMate 3.2 Application-layer event: an
    ITSM-style state change such as an unplanned interruption (incident). The
    vendor-neutral anchor that ServiceNow incidents, ERPNext issues, and Camunda
    process incidents all resolve to.""" ;
    rdfs:seeAlso <https://pubs.opengroup.org/architecture/archimate3-doc/chap09.html> .

:BusinessActor a owl:Class ;
    rdfs:label "Business Actor" ;
    rdfs:comment """Canonical ArchiMate Business Actor: a person or organizational
    entity that performs behaviour. The anchor that ERPNext Employees/Customers
    and ITSM Persons resolve to.""" ;
    rdfs:seeAlso <https://pubs.opengroup.org/architecture/archimate3-doc/chap08.html> .

