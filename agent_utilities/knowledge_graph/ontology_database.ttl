@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://knuckles.team/kg/database> a owl:Ontology ;
    rdfs:label "Relational Database Schema Ontology" ;
    rdfs:comment """Ontology for modeling relational database schemas, tables, columns,
and keys. This maps database artifacts to logical Data Objects at the
ArchiMate Application/Technology layer, allowing code generators and
planners to dynamically reason about data layouts.""" ;
    owl:imports <http://knuckles.team/kg/enterprise> .

:DatabaseSchema a owl:Class ;
    rdfs:label "Database Schema" ;
    rdfs:comment "A logical grouping of database tables and relations." ;
    rdfs:subClassOf :TechnologyLayer .

:DatabaseTable a owl:Class ;
    rdfs:label "Database Table" ;
    rdfs:comment "A database table representing a logical data object." ;
    rdfs:subClassOf :ApplicationLayer .

:DatabaseColumn a owl:Class ;
    rdfs:label "Database Column" ;
    rdfs:comment "An individual column within a database table." ;
    rdfs:subClassOf :ApplicationLayer .

:hasTable a owl:ObjectProperty ;
    rdfs:label "has table" ;
    rdfs:comment "Links a database schema to its constituent tables." ;
    rdfs:domain :DatabaseSchema ;
    rdfs:range :DatabaseTable .

:hasColumn a owl:ObjectProperty ;
    rdfs:label "has column" ;
    rdfs:comment "Links a database table to its constituent columns." ;
    rdfs:domain :DatabaseTable ;
    rdfs:range :DatabaseColumn .

:referencesTable a owl:ObjectProperty ;
    rdfs:label "references table" ;
    rdfs:comment "Links a table to another table via foreign key relationship." ;
    rdfs:domain :DatabaseTable ;
    rdfs:range :DatabaseTable .

:referencesColumn a owl:ObjectProperty ;
    rdfs:label "references column" ;
    rdfs:comment "Links a column to another column via foreign key relationship." ;
    rdfs:domain :DatabaseColumn ;
    rdfs:range :DatabaseColumn .

:dataType a owl:DatatypeProperty ;
    rdfs:label "data type" ;
    rdfs:comment "The relational SQL data type of the column (e.g., VARCHAR, INTEGER, TIMESTAMP)." ;
    rdfs:domain :DatabaseColumn ;
    rdfs:range xsd:string .

:isNullable a owl:DatatypeProperty ;
    rdfs:label "is nullable" ;
    rdfs:comment "Boolean flag indicating if the column accepts NULL values." ;
    rdfs:domain :DatabaseColumn ;
    rdfs:range xsd:boolean .

:isPrimaryKey a owl:DatatypeProperty ;
    rdfs:label "is primary key" ;
    rdfs:comment "Boolean flag indicating if this column is part of the primary key." ;
    rdfs:domain :DatabaseColumn ;
    rdfs:range xsd:boolean .

:isForeignKey a owl:DatatypeProperty ;
    rdfs:label "is foreign key" ;
    rdfs:comment "Boolean flag indicating if this column is part of a foreign key." ;
    rdfs:domain :DatabaseColumn ;
    rdfs:range xsd:boolean .
