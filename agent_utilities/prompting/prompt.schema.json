{
  "$defs": {
    "EngineeringRulesSection": {
      "additionalProperties": true,
      "description": "Task-scoped engineering rules from agent-rules-books.\n\nCONCEPT:AU-KG.ingest.engineering-rules — Engineering Rules Engine\n\nDefines which engineering rules are injected into the agent's prompt\nbased on task context. Supports three loading patterns:\n  - ``always_on``: Rule IDs always included (nano tier recommended)\n  - ``on_demand``: task_type → rule IDs mapping\n  - ``trigger_rules``: Conditional rules activated by context",
      "properties": {
        "always_on": {
          "description": "Rule set IDs always included (e.g., 'clean-code.nano')",
          "items": {
            "type": "string"
          },
          "title": "Always On",
          "type": "array"
        },
        "context_budget": {
          "default": "mini",
          "description": "Maximum tier to use: nano, mini, or full",
          "title": "Context Budget",
          "type": "string"
        },
        "on_demand": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "description": "Task type → rule set IDs (e.g., {'refactoring': ['refactoring.mini']})",
          "title": "On Demand",
          "type": "object"
        },
        "trigger_rules": {
          "description": "Conditional rules activated by task context",
          "items": {
            "$ref": "#/$defs/TriggerRule"
          },
          "title": "Trigger Rules",
          "type": "array"
        }
      },
      "title": "EngineeringRulesSection",
      "type": "object"
    },
    "NestedStructure": {
      "additionalProperties": true,
      "description": "Reusable nested blueprint for structured content (hook/body/cta, etc.).",
