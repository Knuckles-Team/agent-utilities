            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "e.g., curiosity-driven, under 10 words",
          "title": "Hook"
        }
      },
      "title": "NestedStructure",
      "type": "object"
    },
