  "additionalProperties": true,
  "description": "Core standardized model for JSON prompting.\n\nDefines agent system prompts as structured JSON with decomposed sections::\n\n    {\n        \"task\": \"python_programmer\",\n        \"type\": \"prompt\",\n        \"metadata\": {\"topic\": \"...\", \"tone\": \"...\", \"style\": \"...\"},\n        \"identity\": {\"role\": \"...\", \"goal\": \"...\"},\n        \"instructions\": {\"core_directive\": \"...\", \"capabilities\": {...}},\n        \"tools\": [...]\n    }",
  "examples": [
    {
      "identity": {
        "goal": "Craft production-ready Python solutions",
        "role": "Python Systems Wizard"
      },
      "instructions": {
        "capabilities": {
          "modern_python": [
            "decorators",
            "dataclasses",
            "protocols"
          ],
          "testing": [
            "pytest",
            "fixtures",
            "coverage"
          ]
        },
        "core_directive": "Write idiomatic, high-performance Python code."
      },
      "metadata": {
        "description": "Python specialist agent",
        "style": "professional assistant",
        "tone": "technical and precise",
        "topic": "Python Development"
      },
      "task": "python_programmer",
      "tools": [
        "agent-builder",
        "tdd-methodology"
      ],
      "type": "prompt"
    }
  ],
