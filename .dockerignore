# Keep the build context lean: the image builds the wheel from the source tree
# (docker/Dockerfile `COPY . /src`), so it only needs pyproject.toml, README.md,
# LICENSE, and the agent_utilities/ package (with its bundled *.ttl package-data).
# Everything below is dev/test/CI scaffolding or caches that bloat and slow the
# build context (and previously shipped .pytest_tmp/.hypothesis into the build).
.git/
.github/
.specify/
.acp-sessions/
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# Tests, docs, examples, deploy manifests, dev scripts — not part of the wheel.
tests/
docs/
examples/
deploy/
workspace/
scripts/

# Caches / scratch / local state.
.pytest_tmp/
.hypothesis/
.ruff_cache/
.mypy_cache/
*.egg-info/
*.db
*.db-wal
*.sqlite*
.env
.env.example

# Other Dockerfiles / compose — not needed inside the build context.
docker/
mkdocs.yml
