# Keep the build context lean: the images install the PUBLISHED agent-utilities
# wheel from PyPI (docker/Dockerfile + Dockerfile.multiplexer, the agents/* uv
# pattern) — they do NOT build from source. The only context files a build reads are
# overrides.txt (uv pin override) and docker/requirements-multiplexer.txt (the slim
# mcp leg). Everything below is dev/test/CI scaffolding or caches that bloat the context.
.git/
.github/
.specify/
.acp-sessions/
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# Tests, docs, examples, deploy manifests, dev scripts — not part of the wheel.
tests/
docs/
examples/
deploy/
workspace/
scripts/

# Caches / scratch / local state.
.pytest_tmp/
.hypothesis/
.ruff_cache/
.mypy_cache/
*.egg-info/
*.db
*.db-wal
*.sqlite*
.env
.env.example

# Other Dockerfiles / compose — not needed inside the build context, EXCEPT the
# multiplexer runtime-deps list the slim mcp leg installs.
docker/*
!docker/requirements-multiplexer.txt
mkdocs.yml
